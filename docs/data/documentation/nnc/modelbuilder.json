{"metadata":{"modules":[{"name":"NNC"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ModelBuilder"}],"title":"ModelBuilder","symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"ModelBuilder"}],"roleHeading":"Class","externalID":"s:3NNC12ModelBuilderC","role":"symbol"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/NNC"]]},"kind":"symbol","sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/init(_:name:)-4pup0","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/init(_:name:)-55gex"]},{"title":"Instance Methods","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/callAsFunction(_:inputs:_:streamContext:)-101bg","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/callAsFunction(_:inputs:_:streamContext:)-4i10p","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/callAsFunction(inputs:_:streamContext:)-4tnis","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/callAsFunction(inputs:_:streamContext:)-8pae9","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/compile(_:inputs:isEager:)-1lsvw","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/compile(_:inputs:isEager:)-8ge5z","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/compile(inputs:isEager:)-4kat6","doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder\/compile(inputs:isEager:)-4yweq"]}],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/nnc\/modelbuilder"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ModelBuilder","kind":"identif