{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nnc\/modelbuilder"]}],"relationshipsSections":[{"title":"Inherits From","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/AnyModelBuilder"],"kind":"relationships","type":"inheritsFrom"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/NNC"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/NNC\/ModelBuilder"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ModelBuilder","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">","kind":"text"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"A model builder on the other hand doesn’t have that restriction. When input changes,","type":"text"},{"text":" ","type":"text"},{"text":"it simply calls the given builder closure to construct a new model. In such way,","type":"text"},{"text":" ","type":"text"},{"text":"you can continue to use reshape etc to assume fixed inputs and outputs, it will just","type":"text"},{"text":" ","type":"text"},{"text":"work for dynamic inputs. The newly built model will carry over stateful components","type":"text"},{"text":" ","type":"text"},{"text":"(parameters) from the old models, thus, it doesn’t reset your training. This also means","type":"text"},{"text":" ","type":"text"},{"text":"you need to make sure parameter shape won’t change when input changes, otherwise we","type":"text"},{"text":" ","type":"text"},{"text":"will fatal.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation