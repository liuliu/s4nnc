{"metadata":{"externalID":"s:3Gym22InvertedDoublePendulumC","roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"InvertedDoublePendulum"}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedDoublePendulum"}],"symbolKind":"class","title":"InvertedDoublePendulum","modules":[{"name":"Gym"}]},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedDoublePendulum"}]}]},{"kind":"content","content":[{"type":"heading","text":"Description","anchor":"Description","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment originates from control theory and builds on the cartpole"},{"type":"text","text":" "},{"type":"text","text":"environment based on the work done by Barto, Sutton, and Anderson in"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"powered by the Mujoco physics simulator - allowing for more complex experiments"},{"type":"text","text":" "},{"type":"text","text":"(such as varying the effects of gravity or constraints). This environment involves a cart that can"},{"type":"text","text":" "},{"type":"text","text":"moved linearly, with a pole fixed on it and a second pole fixed on the other end of the first one"},{"type":"text","text":" "},{"type":"text","text":"(leaving the second pole as the only one with one free end). The cart can be pushed left or right,"},{"type":"text","text":" "},{"type":"text","text":"and the goal is to balance the second pole on top of the first pole, which is in turn on top of the"},{"type":"text","text":" "},{"type":"text","text":"cart, by applying continuous forces on the cart."}]},{"type":"heading","text":"Action Space","anchor":"Action-Space","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The agent take a 1-element vector for actions."},{"type":"text","text":" "},{"type":"text","text":"The action space is a continuous "},{"code":"(action)","type":"codeVoice"},{"type":"text","text":" in "},{"code":"[-1, 1]","type":"codeVoice"},{"type":"text","text":", where "},{"code":"action","type":"codeVoice"},{"type":"text","text":" represents the"},{"type":"text","text":" "},{"type":"text","text":"numerical force applied to the cart (with magnitude representing the amount of force and"},{"type":"text","text":" "},{"type":"text","text":"sign representing the direction)"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Min"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force applied on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"text":"Force (N)","type":"text"}]}]]]},{"type":"heading","text":"Observation Space","anchor":"Observation-Spa