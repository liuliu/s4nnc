,[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"If using previous Humanoid versions from v4, there have been reported issues that using a Mujoco-Py version > 2.0 results","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"in the contact forces always being 0. As such we recommend to use a Mujoco-Py version < 2.0"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"when using the Ant environment if you would like to report results with contact forces (if"}]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"contact forces are not used in your experiments, you can use version > 2.0).","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"heading","text":"Rewards","anchor":"Rewards","level":3},{"type":"paragraph","inlineContent":[{"text":"The reward consists of three parts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"healthy_reward"}]},{"type":"text","text":": Every timestep that the ant is healthy (see definition in section “Episode Termination”), it gets a reward of fixed value "},{"type":"codeVoice","code":"healthy_reward"}]}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"text":": A reward of moving forward which is measured as","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"(x-coordinate before action - x-coordinate after action)\/dt"}]},{"text":". ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"text":" is the time","type":"text"},{"text":" ","type":"text"},{"text":"between actions and is dependent on the ","type":"text"},{"type":"codeVoice","code":"frame_skip"},{"text":" parameter (default is 5),","type":"text"},{"text":" ","type":"text"},{"text":"where the frametime is 0.01 - making the default ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"dt = 5 * 0.01 = 0.05"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"This reward would be positive if the ant moves forward (in positive x direction).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"ctrl_cost","type":"text"}]},{"text":": A negative reward for penalising the ant if it takes actions","type":"text"},{"text":" ","type":"text"},{"text":"that are too large. It is measured as ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"type":"text","text":" * sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}]},{"text":" ","type":"text"},{"text":"where ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctr_cost_weight","type":"codeVoice"}]},{"text":" is a parameter set for the control and has a default value of 0.5.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"contact_cost"}],"type":"emphasis"},{"type":"text","text":": A negative reward for penalising the ant if the external contact"},{"type":"text","text":" "},{"type":"text","text":"force is too large. It is calculated "},{"inlineContent":[{"type":"codeVoice","code":"contact_cost_weight"},{"type":"text","text":" * sum(clip(external contact"},{"type":"text","text":" "},{"type":"text","text":"force to "},{"type":"codeVoice","code":"contact_force_range"},{"type":"text","text":")"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"reward","type":"text"}]}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"text":"=","type":"text"}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"text":"healthy_reward + forward_reward - ctrl_cost - contact_cost","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms."}]}]}]},{"type":"heading","text":"Starting State","anchor":"Starting-State","level":3},{"type":"paragraph","inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0,  0.75, 1.0, 0.0  … 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":", ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":"] added to the positional values and standard normal noise","type":"text"},{"text":" ","type":"text"},{"text":"with mean 0 and standard deviation ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":" added to the velocity values for","type":"text"},{"text":" ","type":"text"},{"text":"stochasticity. Note that the initial z coordinate is intentionally selected","type":"text"},{"text":" ","type":"text"},{"text":"to be slightly high, thereby indicating a standing up ant. The initial orientation","type":"text"},{"text":" ","type":"text"},{"text":"is designed to make it face forward as well.","type":"text"}]},{"type":"heading","text":"Episode End","anchor":"Episode-End","level":3},{"type":"paragraph","inlineContent":[{"text":"The ant is said to be unhealthy if any of the following happens:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Any of the state space values is no longer finite","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The z-coordinate of the torso is "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" in the closed interval given by "},{"type":"codeVoice","code":"healthy_z_range"},{"type":"text","text":" (defaults to [0.2, 1.0])"},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"terminate_when_unhealthy=True"},{"type":"text","text":" is passed during construction (which is the default),"},{"type":"text","text":" "},{"type":"text","text":"the episode ends when any of the following happens:"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches a 1000 timesteps"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: The ant is unhealthy","type":"text"},{"text":" ","type":"text"},{"text":"If ","type":"text"},{"code":"terminate_when_unhealthy=False","type":"codeVoice"},{"text":" is passed, the episode is ended only when 1000 timesteps are exceeded.","type":"text"}]}]}]},{"type":"heading","text":"Arguments","anchor":"Arguments","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}]},{"type":"codeListing","code":["env = gym.make('Ant-v2')"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"type":"codeListing","code":["env = gym.make('Ant-v4', ctrl_cost_weight=0.1, ...)"],"syntax":null},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"xml_file"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"str","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"ant.xml\""}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.5"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"contact_cost_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"5e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"text":"contact_cost","type":"text"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"healthy_reward"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Constant reward given if the ant is “healthy” after timestep"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"terminate_when_unhealthy","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"bool"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"If true, issue a done signal if the z-coordinate of the torso is no longer in the ","type":"text"},{"code":"healthy_z_range","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"healthy_z_range"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"tuple","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"(0.2, 1)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The ant is considered healthy if the z-coordinate of the torso is in this range"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"contact_force_range","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"tuple","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"(-1, 1)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Contact forces are clipped to this range in the computation of ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"contact_cost"}]}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"bool","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"True","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","text":"Version History","anchor":"Version-History","level":3},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}]}]}]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documenta