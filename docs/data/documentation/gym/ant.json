{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/ant"]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"primaryContentSections":[{"declarations":[{"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Ant"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Description","anchor":"Description","type":"heading","level":3},{"inlineContent":[{"text":"This environment is based on the environment introduced by Schulman,","type":"text"},{"text":" ","type":"text"},{"text":"Moritz, Levine, Jordan and Abbeel in ","type":"text"},{"isActive":true,"identifier":"https:\/\/arxiv.org\/abs\/1506.02438","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The ant is a 3D robot consisting of one torso (free rotational body) with","type":"text"},{"text":" ","type":"text"},{"text":"four legs attached to it with each leg having two links. The goal is to","type":"text"},{"text":" ","type":"text"},{"text":"coordinate the four legs to move in the forward (right) direction by applying","type":"text"},{"text":" ","type":"text"},{"text":"torques on the eight hinges connecting the two links of each leg and the torso","type":"text"},{"text":" ","type":"text"},{"text":"(nine parts and eight hinges).","type":"text"}],"type":"paragraph"},{"text":"Action Space","anchor":"Action-Space","type":"heading","level":3},{"inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (8,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied at the hinge joints.","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text