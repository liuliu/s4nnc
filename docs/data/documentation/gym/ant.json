ong"},{"type":"text","text":" Ant-v4 environment no longer has the following contact forces issue."}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"If using previous Humanoid versions from v4, there have been reported issues that using a Mujoco-Py version > 2.0 results","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"in the contact forces always being 0. As such we recommend to use a Mujoco-Py version < 2.0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"when using the Ant environment if you would like to report results with contact forces (if","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"contact forces are not used in your experiments, you can use version > 2.0).","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"header":"row","type":"table"},{"level":3,"type":"heading","text":"Rewards","anchor":"Rewards"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reward consists of three parts:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"healthy_reward","type":"text"}],"type":"emphasis"},{"type":"text","text":": Every timestep that the ant is healthy (see definition in section “Episode Termination”), it gets a reward of fixed value "},{"type":"codeVoice","code":"healthy_reward"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"forward_reward","type":"text"}],"type":"emphasis"},{"type":"text","text":": A reward of moving forward which is measured as"},{"type":"text","text":" "},{"inlineContent":[{"text":"(x-coordinate before action - x-coordinate after action)\/dt","type":"text"}],"type":"emphasis"},{"type":"text","text":". "},{"inlineContent":[{"type":"text","text":"dt"}],"type":"emphasis"},{"type":"text","text":" is the time"},{"type":"text","text":" "},{"type":"text","text":"between actions and is dependent on the "},{"type":"codeVoice","code":"frame_skip"},{"type":"text","text":" parameter (default is 5),"},{"type":"text","text":" "},{"type":"text","text":"where the frametime is 0.01 - making the default "},{"inlineContent":[{"type":"text","text":"dt = 5 * 0.01 = 0.05"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This reward would be positive if the ant moves forward (in positive x direction)."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"ctrl_cost","type":"text"}],"type":"emphasis"},{"type":"text","text":": A negative reward for penalising the ant if it takes actions"},{"type":"text","text":" "},{"type":"text","text":"that are too large. It is measured as "},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"text":" * sum(action","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"text","text":"where "},{"inlineContent":[{"code":"ctr_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"type":"text","text":" is a parameter set for the control and has a default value of 0.5."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"contact_cost","type":"text"}]},{"type":"text","text":": A negative reward for penalising the ant if the external contact"},{"type":"text","text":" "},{"type":"text","text":"force is too large. It is calculated "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"contact_cost_weight"},{"text":" * sum(clip(external contact","type":"text"},{"text":" ","type":"text"},{"text":"force to ","type":"text"},{"type":"codeVoice","code":"contact_force_range"},{"text":")","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"type":"emphasis","inlineContent":[{"inlineContent":[{"type":"text","text":"reward"}],"type":"strong"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"="}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"healthy_reward + forward_reward - ctrl_cost - contact_cost","type":"text"}]},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms."}]}]}]},{"level":3,"type":"heading","text":"Starting State","anchor":"Starting-State"},{"type":"paragraph","inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0,  0.75, 1.0, 0.0  … 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":", ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":"] added to the positional values and standard normal noise","type":"text"},{"text":" ","type":"text"},{"text":"with mean 0 and standard deviation ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":" added to the velocity values for","type":"text"},{"text":" ","type":"text"},{"text":"stochasticity. Note that the initial z coordinate is intentionally selected","type":"text"},{"text":" ","type":"text"},{"text":"to be slightly high, thereby indicating a standing up ant. The initial orientation","type":"text"},{"text":" ","type":"text"},{"text":"is designed to make it face forward as well.","type":"text"}]},{"level":3,"type":"heading","text":"Episode End","anchor":"Episode-End"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The ant is said to be unhealthy if any of the following happens:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Any of the state space values is no longer finite","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The z-coordinate of the torso is "},{"inlineContent":[{"type":"text","text":"not"}],"type":"strong"},{"type":"text","text":" in the closed interval given by "},{"type":"codeVoice","code":"healthy_z_range"},{"type":"text","text":" (defaults to [0.2, 1.0])"},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"terminate_when_unhealthy=True"},{"type":"text","text":" is passed during construction (which is the default),"},{"type":"text","text":" "},{"type":"text","text":"the episode ends when any of the following happens:"}]}]},{"content":[{"inlineContent":[{"text":"Truncation: The episode duration reaches a 1000 timesteps","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: The ant is unhealthy"},{"type":"text","text":" "},{"type":"text","text":"If "},{"code":"terminate_when_unhealthy=False","type":"codeVoice"},{"type":"text","text":" is passed, the episode is ended only when 1000 timesteps are exceeded."}],"type":"paragraph"}]}]},{"level":3,"type":"heading","text":"Arguments","anchor":"Arguments"},{"type":"paragraph","inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}]},{"type":"codeListing","code":["env = gym.make('Ant-v2')"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"type":"codeListing","code":["env = gym.make('Ant-v4', ctrl_cost_weight=0.1, ...)"],"syntax":null},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"xml_file","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"str","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"ant.xml\""}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"0.5","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"contact_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"5e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"text":"contact_cost","type":"text"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"healthy_reward"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Constant reward given if the ant is “healthy” after timestep"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"terminate_when_unhealthy"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"bool","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"If true, issue a done signal if the z-coordinate of the torso is no longer in the ","type":"text"},{"type":"codeVoice","code":"healthy_z_range"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"healthy_z_range","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"tuple"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"(0.2, 1)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The ant is considered healthy if the z-coordinate of the torso is in this range"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"contact_force_range","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"tuple"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"(-1, 1)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Contact forces are clipped to this range in the computation of ","type":"text"},{"inlineContent":[{"type":"text","text":"contact_cost"}],"type":"emphasis"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"bool"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"level":3,"type":"heading","text":"Version History","anchor":"Version-History"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"kind":"relationships","title":"Conforms To"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Ant/data":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjData","preciseIdentifier":"s:6MuJoCo6MjDataV","kind":"typeIdentifier"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Ant\/data","role":"symbol","title":"data","abstract":[],"url":"\/documentation\/gym\/ant\/data","type":"topic","kind":"symbol"},"https://arxiv.org/abs/1506.02438":{"type":"link","titleInlineContent":[{"type":"text","text":"“High-Dimensional Continuous Control"},{"type":"text","text":" "},{"type":"text","text":"Using Generalized Advantage Estimation”"}],"title":"“High-Dimensional Continuous Control Using Generalized Advantage Estimation”","url":"https:\/\/arxiv.org\/abs\/1506.02438","identifier":"https:\/\/arxiv.org\/abs\/1506.02438"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"url":"\/documentation\/gym\/mujocoenv","abstract":[],"kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","role":"symbol","title":"MuJoCoEnv"},"https://mujoco.readthedocs.io/en/latest/XMLreference.html":{"type":"link","titleInlineContent":[{"type":"text","text":"Mujoco Documentation"}],"title":"Mujoco Documentation","url":"https:\/\/mujoco.readthedocs.io\/en\/latest\/XMLreference.html","identifier":"https:\/\/mujoco.readthedocs.io\/en\/latest\/XMLreference.html"},"doc://org.liu