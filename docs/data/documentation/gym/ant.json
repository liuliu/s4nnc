".","type":"text"},{"text":" ","type":"text"},{"text":"The ant is a 3D robot consisting of one torso (free rotational body) with","type":"text"},{"text":" ","type":"text"},{"text":"four legs attached to it with each leg having two links. The goal is to","type":"text"},{"text":" ","type":"text"},{"text":"coordinate the four legs to move in the forward (right) direction by applying","type":"text"},{"text":" ","type":"text"},{"text":"torques on the eight hinges connecting the two links of each leg and the torso","type":"text"},{"text":" ","type":"text"},{"text":"(nine parts and eight hinges).","type":"text"}]},{"level":3,"anchor":"Action-Space","text":"Action Space","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (8,), float32)"},{"type":"text","text":". An action represents the torques applied at the hinge joints."}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the rotor between the torso and front left hip","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hip_1 (front_left_leg)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}