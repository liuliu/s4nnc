bs\/1506.02438","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The ant is a 3D robot consisting of one torso (free rotational body) with","type":"text"},{"text":" ","type":"text"},{"text":"four legs attached to it with each leg having two links. The goal is to","type":"text"},{"text":" ","type":"text"},{"text":"coordinate the four legs to move in the forward (right) direction by applying","type":"text"},{"text":" ","type":"text"},{"text":"torques on the eight hinges connecting the two links of each leg and the torso","type":"text"},{"text":" ","type":"text"},{"text":"(nine parts and eight hinges).","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Action Space","anchor":"Action-Space"},{"inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (8,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied at the hinge joints.","type":"text"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Action","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the rotor between the torso and front left hip"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hip_1 (front_left_leg)"}],"type":"para