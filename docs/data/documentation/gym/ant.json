{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/ant"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Ant"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Ant","kind":"identifier"}],"platforms":["Linux"]}]},{"content":[{"text":"Description","level":3,"anchor":"Description","type":"heading"},{"inlineContent":[{"text":"This environment is based on the environment introduced by Schulman,","type":"text"},{"text":" ","type":"text"},{"text":"Moritz, Levine, Jordan and Abbeel in ","type":"text"},{"isActive":true,"identifier":"https:\/\/arxiv.org\/abs\/1506.02438","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The ant is a 3D robot consisting of one torso (free rotational body) with","type":"text"},{"text":" ","type":"text"},{"text":"four legs attached to it with each leg having two links. The goal is to","type":"text"},{"text":" ","type":"text"},{"text":"coordinate the four legs to move in the forward (right) direction by applying","type":"text"},{"text":" ","type":"text"},{"text":"torques on the eight hinges connecting the two links of each leg and the torso","type":"text"},{"text":" ","type":"text"},{"text":"(nine parts and eight hinges).","type":"text"}],"type":"paragraph"},{"text":"Action Space","level":3,"anchor":"Action-Space","type":"heading"},{"inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (8,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied at the hinge joints.","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Action"}]