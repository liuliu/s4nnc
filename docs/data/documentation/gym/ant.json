ion"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"of the torso will be returned in ","type":"text"},{"type":"codeVoice","code":"info"},{"text":" with keys ","type":"text"},{"type":"codeVoice","code":"\"x_position\""},{"text":" and ","type":"text"},{"type":"codeVoice","code":"\"y_position\""},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"However, by default, an observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(111,)"},{"text":" ","type":"text"},{"text":"where the elements correspond to the following:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observation"}]}],[{"type":"paragraph","inlineContent":[{"text":"Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Max"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"z-coordinate of the torso (centre)"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"torso"}]}],[{"type":"paragraph","inlineContent":[{"text":"free","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"position (m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"x-orientation of the torso (centre)","type":"text"}]}],[{"type":"paragraph","inlin