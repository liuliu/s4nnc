,"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","text":"Observation Space","anchor":"Observation-Space","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Observations consist of positional values of different body parts of the ant,"},{"type":"text","text":" "},{"type":"text","text":"followed by the velocities of those individual parts (their derivatives) with all"},{"type":"text","text":" "},{"type":"text","text":"the positions ordered before all the velocities."},{"type":"text","text":" "},{"type":"text","text":"By default, observations do not include the x- and y-coordinates of the ant’s torso. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"In that case, the observation space will have 113 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y- coordinates of the ant’s torso."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"of the torso will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with keys "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"y_position\""},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"However, by default, an observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(111,)"},{"type":"text","text":" "},{"type":"text","text":"where the elements correspond to the following:"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Observation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"z-coordinate of the torso (centre)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torso"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"free"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"position (m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"x-orientation of the torso (centre)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torso","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"free"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"angle (rad)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"text":"y-orientation of the torso (centre)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"