neContent":[{"type":"text","text":"in the contact forces always being 0. As such we recommend to use a Mujoco-Py version < 2.0"}]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}]],[[{"inlineContent":[{"text":"when using the Ant environment if you would like to report results with contact forces (if","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"contact forces are not used in your experiments, you can use version > 2.0).","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"type":"table"},{"anchor":"Rewards","text":"Rewards","level":3,"type":"heading"},{"inlineContent":[{"text":"The reward consists of three parts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"healthy_reward"}],"type":"emphasis"},{"type":"text","text":": Every timestep that the ant is healthy (see definition in section “Episode Termination”), it gets a reward of fixed value "},{"type":"codeVoice","code":"healthy_reward"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"text":": A reward of moving forward which is measured as","type":"text"},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"(x-coordinate before action - x-coordinate after action)\/dt"}]},{"text":". ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"text":" is the time","type":"text"},{"text":" ","type":"text"},{"text":"between actions and is dependent on the ","type":"text"},{"code":"frame_skip","type":"codeVoice"},{"text":" parameter (default is 5),","type":"text"},{"text":" ","type":"text"},{"text":"where the frametime is 0.01 - making the default ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"dt = 5 * 0.01 = 0.05","type":"text"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"This reward would be positive if the ant moves forward (in positive x direction).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"ctrl_cost","type":"text"}]},{"type":"text","text":": A negative reward for penalising the ant if it takes actions"},{"type":"text","text":" "},{"type":"text","text":"that are too large. It is measured as "},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"text":" * sum(action","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"where "},{"type":"emphasis","inlineContent":[{"code":"ctr_cost_weight","type":"codeVoice"}]},{"type":"text","text":" is a parameter set for the control and has a default value of 0.5."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"contact_cost"}],"type":"emphasis"},{"type":"text","text":": A negative reward for penalising the ant if the external contact"},{"type":"text","text":" "},{"type":"text","text":"force is too large. It is calculated "},{"inlineContent":[{"code":"contact_cost_weight","type":"codeVoice"},{"text":" * sum(clip(external contact","type":"text"},{"text":" ","type":"text"},{"text":"force to ","type":"text"},{"code":"contact_force_range","type":"codeVoice"},{"text":")","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}],"type":"emphasis"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"="}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"text":"healthy_reward + forward_reward - ctrl_cost - contact_cost","type":"text"}],"type":"emphasis"},{"type":"text","text":" and "},{"code":"info","type":"codeVoice"},{"type":"text","text":" will also contain the individual reward terms."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Starting-State","text":"Starting State","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0,  0.75, 1.0, 0.0  … 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-"},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":", "},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":"] added to the positional values and standard normal noise"},{"type":"text","text":" "},{"type":"text","text":"with mean 0 and standard deviation "},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":" added to the velocity values for"},{"type":"text","text":" "},{"type":"text","text":"stochasticity. Note that the initial z coordinate is intentionally selected"},{"type":"text","text":" "},{"type":"text","text":"to be slightly high, thereby indicating a standing up ant. The initial orientation"},{"type":"text","text":" "},{"type":"text","text":"is designed to make it face forward as well."}],"type":"paragraph"},{"anchor":"Episode-End","text":"Episode End","level":3,"type":"heading"},{"inlineContent":[{"text":"The ant is said to be unhealthy if any of the following happens:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any of the state space values is no longer finite"}]}]},{"content":[{"inlineContent":[{"text":"The z-coordinate of the torso is ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"strong"},{"text":" in the closed interval given by ","type":"text"},{"type":"codeVoice","code":"healthy_z_range"},{"text":" (defaults to [0.2, 1.0])","type":"text"},{"text":" ","type":"text"},{"text":"If ","type":"text"},{"type":"codeVoice","code":"terminate_when_unhealthy=True"},{"text":" is passed during construction (which is the default),","type":"text"},{"text":" ","type":"text"},{"text":"the episode ends when any of the following happens:","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches a 1000 timesteps"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: The ant is unhealthy"},{"type":"text","text":" "},{"type":"text","text":"If "},{"code":"terminate_when_unhealthy=False","type":"codeVoice"},{"type":"text","text":" is passed, the episode is ended only when 1000 timesteps are exceeded."}]}]}],"type":"orderedList"},{"anchor":"Arguments","text":"Arguments","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}],"type":"paragraph"},{"code":["env = gym.make('Ant-v2')"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}],"type":"paragraph"},{"code":["env = gym.make('Ant-v4', ctrl_cost_weight=0.1, ...)"],"syntax":null,"type":"codeListing"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"