{"kind":"symbol","identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To","type":"conformsTo"}],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"roleHeading":"Class","externalID":"s:3Gym16InvertedPendulumC","symbolKind":"class","navigatorTitle":[{"text":"InvertedPendulum","kind":"identifier"}],"role":"symbol","modules":[{"name":"Gym"}],"title":"InvertedPendulum"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"platforms":["Linux"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Description","anchor":"Description","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}],"type":"paragraph"},{"text":"Action Space","anchor":"Action-Space","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The agent take a 1-element vector for actions."},{"type":"text","text":" "},{"type":"text","text":"The action space is a continuous "},{"type":"codeVoice","code":"(action)"},{"type":"text","text":" in "},{"type":"codeVoice","code":"[-3, 3]"},{"type":"text","text":", where "},{"type":"codeVoice","code":"action"},{"type":"text","text":" represents"},{"type":"text","text":" "},{"type":"text","text":"the numerical force applied to the cart (with magnitude representing the amount of"},{"type":"text","text":" "},{"type":"text","text":"force and sign representing the direction)"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Force applied on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Force (N)","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Observation Space","anchor":"Observation-Space","level":3,"type":"heading"},{"inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(4,)"},{"text":" where the elements correspond to the following:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Observation"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"position of the cart along the linear surface","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"position (m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angle (rad)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"linear velocity of the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slider"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"velocity (m\/s)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Rewards","anchor":"Rewards","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}],"type":"paragraph"},{"text":"Starting State","anchor":"Starting-State","level":3,"type":"heading"},{"inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-0.01, 0.01] added to the values for stochasticity.","type":"text"}],"type":"paragraph"},{"text":"Episode End","anchor":"Episode-End","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The episode ends when any of the following happens:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}]}]}],"type":"orderedList"},{"text":"Arguments","anchor":"Arguments","level":3,"type":"heading"},{"inlineContent":[{"text":"No additional arguments are currently supported.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["env = gym.make('InvertedPendulum-v4')"]},{"inlineContent":[{"text":"There is no v3 for InvertedPendulum, unlike the robot environments where a","type":"text"},{"text":" ","type":"text"},{"text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"text":"Version History","anchor":"Version-History","level":3,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/data":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjData","kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo6MjDataV"}],"title":"data","kind":"symbol","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","role":"symbol","url":"\/documentation\/gym\/invertedpendulum\/data","abstract":[]},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum","abstract":[],"title":"InvertedPendulum","type":"topic","url":"\/documentation\/gym\/invertedpendulum","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier",