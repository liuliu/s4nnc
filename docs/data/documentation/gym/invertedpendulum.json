{"sections":[],"metadata":{"symbolKind":"class","roleHeading":"Class","modules":[{"name":"Gym"}],"externalID":"s:3Gym16InvertedPendulumC","title":"InvertedPendulum","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"navigatorTitle":[{"kind":"identifier","text":"InvertedPendulum"}],"role":"symbol"},"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Description","anchor":"Description","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","isActive":true,"identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}]},{"type":"heading","text":"Action Space","anchor":"Action-Space","level":3},{"type":"paragraph","inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"type":"codeVoice","code":"(action)"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"[-3, 3]"},{"text":", where ","type":"text"},{"type":"codeVoice","code":"action"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}]},{"rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force applied on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force (N)"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"type":"heading","text":"Observation Space","anchor":"Observation-Space","level":3},{"type":"paragraph","inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(4,)"},{"text":" where the elements correspond to the following:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Observation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Max"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position of the cart along the linear surface"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position (m)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"vertical angle of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"linear velocity of the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"velocity (m\/s)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"anglular velocity (rad\/s)","type":"text"}]}]]],"header":"row","type":"table"},{"type":"heading","text":"Rewards","anchor":"Rewards","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}]},{"type":"heading","text":"Starting State","anchor":"Starting-State","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}]},{"type":"heading","text":"Episode End","anchor":"Episode-End","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode ends when any of the following happens:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}],"type":"paragraph"}]}]},{"type":"heading","text":"Arguments","anchor":"Arguments","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported."}]},{"type":"codeListing","syntax":null,"code":["env = gym.make('InvertedPendulum-v4')"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"type":"heading","text":"Version History","anchor":"Version-History","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}],"type":"paragraph"}]}]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym":{"url":"\/documentation\/gym","type":"topic","title":"Gym","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","abstract":[],"role":"collection"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/init()":{"url":"\/documentation\/gym\/invertedpendulum\/init()","title":"init()","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"throws","kind":"keyword"}],"kind":"symbol","role":"symbol","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","abstract":[],"role":"symbol","type":"topic","title":"MuJoCoEnv","fragments":[{"kind":"keyword",