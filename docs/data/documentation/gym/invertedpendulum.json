{"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"sections":[],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"title":"Default Implementations","generated":true}],"variants":[{"paths":["\/documentation\/gym\/invertedpendulum"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"languages":["swift"],"platforms":["Linux"]}]},{"kind":"content","content":[{"level":3,"anchor":"Description","text":"Description","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}]},{"level":3,"anchor":"Action-Space","text":"Action Space","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"type":"codeVoice","code":"(action)"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"[-3, 3]"},{"text":", where ","type":"text"},{"type":"codeVoice","code":"action"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force applied on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force (N)"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Observation-Space","text":"Observation Space","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state space consists of positional values of different body parts of"},{"type":"text","text":" "},{"type":"text","text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)"},{"type":"text","text":" "},{"type":"text","text":"with all the positions ordered before all the velocities."},{"type":"text","text":" "},{"type":"text","text":"The observation is a "},{"code":"ndarray","type":"codeVoice"},{"type":"text","text":" with shape "},{"code":"(4,)","type":"codeVoice"},{"type":"text","text":" where the elements correspond to the following:"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Observation"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"position of the cart along the linear surface"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slider"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"position (m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angle (rad)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"linear velocity of the cart"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"text":"velocity (m\/s)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Rewards","text":"Rewards","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}]},{"level":3,"anchor":"Starting-State","text":"Starting State","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}]},{"level":3,"anchor":"Episode-End","text":"Episode End","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode ends when any of the following happens:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: Any of the state space values is no longer finite."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian.","type":"text"}]}]}]},{"level":3,"anchor":"Arguments","text":"Arguments","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported."}]},{"syntax":null,"code":["env = gym.make('InvertedPendulum-v4')"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"level":3,"anchor":"Version-History","text":"Version History","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"metadata":{"symbolKind":"class","externalID":"s:3Gym16InvertedPendulumC","modules":[{"name":"Gym"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"title":"InvertedPendulum","navigatorTitle":[{"kind":"identifier","text":"InvertedPendulum"}],"roleHeading":"Class","role":"symbol"},"kind":"symbol","references":{"doc://org.liuliu.s4nnc/documentation/Gym":{"type":"topic","abstract":[],"title":"Gym","kind":"symbol","url":"\/documentation\/gym","role":"collection","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","url":"\/documentation\/gym\/mujocoenv","abstract":[],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MuJoCoEnv"}],"title":"MuJoCoEnv"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/data":{"kind":"symbol","type":"topic","role":"symbol","abstract":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"