{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"sections":[],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"title":"Default Implementations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"metadata":{"roleHeading":"Class","symbolKind":"class","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"externalID":"s:3Gym16InvertedPendulumC","modules":[{"name":"Gym"}],"navigatorTitle":[{"kind":"identifier","text":"InvertedPendulum"}],"title":"InvertedPendulum"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"platforms":["Linux"]}]},{"content":[{"text":"Description","anchor":"Description","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}]},{"text":"Action Space","anchor":"Action-Space","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The agent take a 1-element vector for actions."},{"type":"text","text":" "},{"type":"text","text":"The action space is a continuous "},{"code":"(action)","type":"codeVoice"},{"type":"text","text":" in "},{"code":"[-3, 3]","type":"codeVoice"},{"type":"text","text":", where "},{"code":"action","type":"codeVoice"},{"type":"text","text":" represents"},{"type":"text","text":" "},{"type":"text","text":"the numerical force applied to the cart (with magnitude representing the amount of"},{"type":"text","text":" "},{"type":"text","text":"force and sign representing the direction)"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Action"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force applied on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force (N)"}]}]]],"header":"row","type":"table"},{"text":"Observation Space","anchor":"Observation-Space","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(4,)"},{"text":" where the elements correspond to the following:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observation"}]}],[{"type":"paragraph","inlineContent":[{"text":"Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position of the cart along the linear surface"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position (m)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"text":"linear velocity of the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"velocity (m\/s)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angular velocity of the pole on the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"anglular velocity (rad\/s)","type":"text"}]}]]],"header":"row","type":"table"},{"text":"Rewards","anchor":"Rewards","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)","type":"text"},{"text":" ","type":"text"},{"text":"as long as possible - as such a reward of +1 is awarded for each timestep that","type":"text"},{"text":" ","type":"text"},{"text":"the pole is upright.","type":"text"}]},{"text":"Starting State","anchor":"Starting-State","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-0.01, 0.01] added to the values for stochasticity.","type":"text"}]},{"text":"Episode End","anchor":"Episode-End","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode ends when any of the following happens:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches 1000 timesteps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: Any of the state space values is no longer finite."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}],"type":"paragraph"}]}],"type":"orderedList"},{"text":"Arguments","anchor":"Arguments","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"No additional arguments are currently supported.","type":"text"}]},{"code":["env = gym.make('InvertedPendulum-v4')"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"text":"Version History","anchor":"Version-History","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/init()":{"url":"\/documentation\/gym\/invertedpendulum\/init()","fragments":[{"text":"init","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"throws","kind":"keyword"}],"abstract":[],"kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()","title":"init()"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/Env-Implementations":{"role":"collectionGroup","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations","title":"Env Implementations","url":"\/documentation\/gym\/invertedpendulum\/env-implementations","kind":"article","abstract":[]},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/model":{"role":"symbol","