{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"]},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum","interfaceLanguage":"swift"},"metadata":{"title":"InvertedPendulum","roleHeading":"Class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"externalID":"s:3Gym16InvertedPendulumC","navigatorTitle":[{"text":"InvertedPendulum","kind":"identifier"}],"modules":[{"name":"Gym"}],"symbolKind":"class"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":3,"anchor":"Description","type":"heading","text":"Description"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}]},{"level":3,"anchor":"Action-Space","type":"heading","text":"Action Space"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The agent take a 1-element vector for actions."},{"type":"text","text":" "},{"type":"text","text":"The action space is a continuous "},{"code":"(action)","type":"codeVoice"},{"type":"text","text":" in "},{"code":"[-3, 3]","type":"codeVoice"},{"type":"text","text":", where "},{"code":"action","type":"codeVoice"},{"type":"text","text":" represents"},{"type":"text","text":" "},{"type":"text","text":"the numerical force applied to the cart (with magnitude representing the amount of"},{"type":"text","text":" "},{"type":"text","text":"force and sign representing the direction)"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Action","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force applied on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force (N)"}],"type":"paragraph"}]]],"header":"row"},{"level":3,"anchor":"Observation-Space","type":"heading","text":"Observation Space"},{"type":"paragraph","inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(4,)"},{"text":" where the elements correspond to the following:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Min"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"text":"position of the cart along the linear surface","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"position (m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"vertical angle of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"linear velocity of the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"velocity (m\/s)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}]}]]],"header":"row"},{"level":3,"anchor":"Rewards","type":"heading","text":"Rewards"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}]},{"level":3,"anchor":"Starting-State","type":"heading","text":"Starting State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}]},{"level":3,"anchor":"Episode-End","type":"heading","text":"Episode End"},{"type":"paragraph","inlineContent":[{"text":"The episode ends when any of the following happens:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches 1000 timesteps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}],"type":"paragraph"}]}],"type":"orderedList"},{"level":3,"anchor":"Arguments","type":"heading","text":"Arguments"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported."}]},{"type":"codeListing","syntax":null,"code":["env = gym.make('InvertedPendulum-v4')"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"level":3,"anchor":"Version-History","type":"heading","text":"Version History"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}],"type":"unorderedList"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/data":{"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo6MjDataV","text":"MjData"}],"type":"topic","url":"\/documentation\/gym\/invertedpendulum\/data","kind":"symbol","title":"data"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/init()":{"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"() "},{"text":"throws","kind":"keyword"}],"type":"topic","url":"\/documentation\/