{"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"kind":"relationships","type":"conformsTo"}],"variants":[{"paths":["\/documentation\/gym\/invertedpendulum"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"]},{"title":"Default Implementations","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"generated":true}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"navigatorTitle":[{"kind":"identifier","text":"InvertedPendulum"}],"externalID":"s:3Gym16InvertedPendulumC","title":"InvertedPendulum","symbolKind":"class","roleHeading":"Class","modules":[{"name":"Gym"}]},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"kind":"symbol","identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Description","anchor":"Description","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}],"type":"paragraph"},{"text":"Action Space","anchor":"Action-Space","type":"heading","level":3},{"inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"type":"codeVoice","code":"(action)"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"[-3, 3]"},{"text":", where ","type":"text"},{"type":"codeVoice","code":"action"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Action"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Min"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force applied on the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-3"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"text":"Force (N)","type":"text"}]}]]]},{"text":"Observation Space","anchor":"Observation-Space","type":"heading","level":3},{"inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(4,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Observation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Min"}]}],[{"type":"paragraph","inlineContent":[{"text":"Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"position of the cart along the linear surface","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"position (m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"vertical angle of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"linear velocity of the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"velocity (m\/s)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}]}]]]},{"text":"Rewards","anchor":"Rewards","type":"heading","level":3},{"inlineContent":[{"text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)","type":"text"},{"text":" ","type":"text"},{"text":"as long as possible - as such a reward of +1 is awarded for each timestep that","type":"text"},{"text":" ","type":"text"},{"text":"the pole is upright.","type":"text"}],"type":"paragraph"},{"text":"Starting State","anchor":"Starting-State","type":"heading","level":3},{"inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-0.01, 0.01] added to the values for stochasticity.","type":"text"}],"type":"paragraph"},{"text":"Episode End","anchor":"Episode-End","type":"heading","level":3},{"inlineContent":[{"text":"The episode ends when any of the following happens:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches 1000 timesteps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: Any of the state space values is no longer finite."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian.","type":"text"}]}]}]},{"text":"Arguments","anchor":"Arguments","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"No additional arguments are currently supported."}],"type":"paragraph"},{"code":["env = gym.make('InvertedPendulum-v4')"],"type":"codeListing","syntax":null},{"inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}],"type":"paragraph"},{"text":"Version History","anchor":"Version-History","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}]}]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"navigatorTitle":[{"kind":"identifier","text":"Env"}],"abstract":[],"kind":"symbol","title":"Env","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"url":"\/documentation\/gym\/env","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/Env-Implementations":{"abstract":[],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations","title":"Env Implementations","kind":"article","url":"\/documentation\/gym\/invertedpendulum\/env-implementations","role":"collectionGroup"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/init()":{"abstract":[],"url":"\/docum