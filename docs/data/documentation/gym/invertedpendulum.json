{"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"]},{"generated":true,"title":"Default Implementations","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"platforms":["Linux"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":3,"anchor":"Description","text":"Description"},{"inlineContent":[{"text":"This environment is the cartpole environment based on the work done by","type":"text"},{"text":" ","type":"text"},{"text":"Barto, Sutton, and Anderson in ","type":"text"},{"isActive":true,"identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"just like in the classic environments but now powered by the Mujoco physics simulator -","type":"text"},{"text":" ","type":"text"},{"text":"allowing for more complex experiments (such as varying the effects of gravity).","type":"text"},{"text":" ","type":"text"},{"text":"This environment involves a cart that can moved linearly, with a pole fixed on it","type":"text"},{"text":" ","type":"text"},{"text":"at one end and having another end free. The cart can be pushed left or right, and the","type":"text"},{"text":" ","type":"text"},{"text":"goal is to balance the pole on the top of the cart by applying forces on the cart.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Action-Space","text":"Action Space"},{"inlineContent":[{"type":"text","text":"The agent take a 1-element vector for actions."},{"type":"text","text":" "},{"type":"text","text":"The action space is a continuous "},{"code":"(action)","type":"codeVoice"},{"type":"text","text":" in "},{"code":"[-3, 3]","type":"codeVoice"},{"type":"text","text":", where "},{"code":"action","type":"codeVoice"},{"type":"text","text":" represents"},{"type":"text","text":" "},{"type":"text","text":"the numerical force applied to the cart (with magnitude representing the amount of"},{"type":"text","text":" "},{"type":"text","text":"force and sign representing the direction)"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force applied on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force (N)"}],"type":"paragraph"}]]]},{"type":"heading","level":3,"anchor":"Observation-Space","text":"Observation Space"},{"inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(4,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Observation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"text":"position of the cart along the linear surface","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position (m)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"linear velocity of the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"velocity (m\/s)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"text":"angular velocity of the pole on the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"anglular velocity (rad\/s)","type":"text"}]}]]]},{"type":"heading","level":3,"anchor":"Rewards","text":"Rewards"},{"inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Starting-State","text":"Starting State"},{"inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Episode-End","text":"Episode End"},{"inlineContent":[{"type":"text","text":"The episode ends when any of the following happens:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}]}]}],"type":"orderedList"},{"type":"heading","level":3,"anchor":"Arguments","text":"Arguments"},{"inlineContent":[{"text":"No additional arguments are currently supported.","type":"text"}],"type":"paragraph"},{"code":["env = gym.make('InvertedPendulum-v4')"],"type":"codeListing","syntax":null},{"inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Version-History","text":"Version History"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}]}]}],"type":"unorderedList"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"navigatorTitle":[{"text":"InvertedPendulum","kind":"identifier"}],"roleHeading":"Class","symbolKind":"class","title":"InvertedPendulum","modules":[{"name":"Gym"}],"externalID":"s:3Gym16InvertedPendulumC","role":"symbol"},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/data":{"role":"symbol","type":"topic","abstract":[],"url":"\/documentation\/gym\/invertedpendulum\/data","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","title":"data","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjData","preciseIdentifier":"s:6MuJoCo6MjDataV"}]},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/model":{"role":"symbol","type":"topic","abstract":[],"url":"\/documentation\/gym\/invertedpendulum\/model","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model","title":"model","fragments":[{"kind":"keyword","text":"let"},{"kind":"