{"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Description","anchor":"Description","level":3},{"type":"paragraph","inlineContent":[{"text":"This environment is the cartpole environment based on the work done by","type":"text"},{"text":" ","type":"text"},{"text":"Barto, Sutton, and Anderson in ","type":"text"},{"identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"just like in the classic environments but now powered by the Mujoco physics simulator -","type":"text"},{"text":" ","type":"text"},{"text":"allowing for more complex experiments (such as varying the effects of gravity).","type":"text"},{"text":" ","type":"text"},{"text":"This environment involves a cart that can moved linearly, with a pole fixed on it","type":"text"},{"text":" ","type":"text"},{"text":"at one end and having another end free. The cart can be pushed left or right, and the","type":"text"},{"text":" ","type":"text"},{"text":"goal is to balance the pole on the top of the cart by applying forces on the cart.","type":"text"}]},{"type":"heading","text":"Action Space","anchor":"Action-Space","level":3},{"type":"paragraph","inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"type":"codeVoice","code":"(action)"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"[-3, 3]"},{"text":", where ","type":"text"},{"type":"codeVoice","code":"action"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Action"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Min"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Force applied on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Force (N)"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"heading","text":"Observation Space","anchor":"Observation-Space","level":3},{"type":"paragraph","inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(4,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Min"}]}],[{"type":"paragraph","inlineContent":[{"text":"Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position of the cart along the linear surface"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"text":"position (m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"vertical angle of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"text":"linear velocity of the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"velocity (m\/s)"}]}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angular velocity of the pole on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"heading","text":"Rewards","anchor":"Rewards","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}]},{"type":"heading","text":"Starting State","anchor":"Starting-State","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}]},{"type":"heading","text":"Episode End","anchor":"Episode-End","level":3},{"type":"paragraph","inlineContent":[{"text":"The episode ends when any of the following happens:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","text":"Arguments","anchor":"Arguments","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported."}]},{"type":"codeListing","syntax":null,"code":["env = gym.make('InvertedPendulum-v4')"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"type":"heading","text":"Version History","anchor":"Version-History","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}]}]}],"metadata":{"role":"symbol","symbolKind":"class","externalID":"s:3Gym16InvertedPendulumC","fragments":[{"text":"class","kind":"keyword"},{"