{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"metadata":{"symbolKind":"class","roleHeading":"Class","modules":[{"name":"Gym"}],"title":"InvertedPendulum","navigatorTitle":[{"text":"InvertedPendulum","kind":"identifier"}],"externalID":"s:3Gym16InvertedPendulumC","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InvertedPendulum"}],"platforms":["Linux"]}],"kind":"declarations"},{"content":[{"level":3,"anchor":"Description","text":"Description","type":"heading"},{"inlineContent":[{"type":"text","text":"This environment is the cartpole environment based on the work done by"},{"type":"text","text":" "},{"type":"text","text":"Barto, Sutton, and Anderson in "},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"just like in the classic environments but now powered by the Mujoco physics simulator -"},{"type":"text","text":" "},{"type":"text","text":"allowing for more complex experiments (such as varying the effects of gravity)."},{"type":"text","text":" "},{"type":"text","text":"This environment involves a cart that can moved linearly, with a pole fixed on it"},{"type":"text","text":" "},{"type":"text","text":"at one end and having another end free. The cart can be pushed left or right, and the"},{"type":"text","text":" "},{"type":"text","text":"goal is to balance the pole on the top of the cart by applying forces on the cart."}],"type":"paragraph"},{"level":3,"anchor":"Action-Space","text":"Action Space","type":"heading"},{"inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"code":"(action)","type":"codeVoice"},{"text":" in ","type":"text"},{"code":"[-3, 3]","type":"codeVoice"},{"text":", where ","type":"text"},{"code":"action","type":"codeVoice"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force applied on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Force (N)"}]}]]],"header":"row","type":"table"},{"level":3,"anchor":"Observation-Space","text":"Observation Space","type":"heading"},{"inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(4,)"},{"text":" where the elements correspond to the following:","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observation"}]}],[{"type":"paragraph","inlineContent":[{"text":"Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"position of the cart along the linear surface"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"slider","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slide"}]}],[{"type":"paragraph","inlineContent":[{"text":"position (m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"linear velocity of the cart"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"slider"}]}],[{"type":"paragraph","inlineContent":[{"text":"slide","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"velocity (m\/s)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"anglular velocity (rad\/s)"}]}]]],"header":"row","type":"table"},{"level":3,"anchor":"Rewards","text":"Rewards","type":"heading"},{"inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}],"type":"paragraph"},{"level":3,"anchor":"Starting-State","text":"Starting State","type":"heading"},{"inlineContent":[{"type":"text","text":"All observations start in state"},{"type":"text","text":" "},{"type":"text","text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range"},{"type":"text","text":" "},{"type":"text","text":"of [-0.01, 0.01] added to the values for stochasticity."}],"type":"paragraph"},{"level":3,"anchor":"Episode-End","text":"Episode End","type":"heading"},{"inlineContent":[{"text":"The episode ends when any of the following happens:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Truncation: The episode duration reaches 1000 timesteps.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: Any of the state space values is no longer finite.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian."}]}]}],"type":"orderedList"},{"level":3,"anchor":"Arguments","text":"Arguments","type":"heading"},{"inlineContent":[{"text":"No additional arguments are currently supported.","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["env = gym.make('InvertedPendulum-v4')"],"type":"codeListing"},{"inlineContent":[{"text":"There is no v3 for InvertedPendulum, unlike the robot environments where a","type":"text"},{"text":" ","type":"text"},{"text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Version-History","text":"Version History","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)"}]}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"variants":[{"paths":["\/documentation\/gym\/invertedpendulum"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"abstract":[],"kind":"symbol","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","url":"\/documentation\/gym\/mujocoenv","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"title":"MuJoCoEnv"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"abstract":[],"kind":"symbol","navigatorTitle":[{"text":"Env","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","url":"\/documentation\/gym\/env","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Env","kind":"identifier"}],"title":"Env"},"doc://org.liuliu.s4