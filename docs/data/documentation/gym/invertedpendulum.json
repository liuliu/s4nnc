{"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum"},"sections":[],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/init()"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/invertedpendulum"]}],"metadata":{"navigatorTitle":[{"text":"InvertedPendulum","kind":"identifier"}],"symbolKind":"class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"externalID":"s:3Gym16InvertedPendulumC","roleHeading":"Class","modules":[{"name":"Gym"}],"title":"InvertedPendulum"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InvertedPendulum","kind":"identifier"}],"platforms":["Linux"]}],"kind":"declarations"},{"content":[{"anchor":"Description","level":3,"type":"heading","text":"Description"},{"inlineContent":[{"text":"This environment is the cartpole environment based on the work done by","type":"text"},{"text":" ","type":"text"},{"text":"Barto, Sutton, and Anderson in ","type":"text"},{"type":"reference","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"just like in the classic environments but now powered by the Mujoco physics simulator -","type":"text"},{"text":" ","type":"text"},{"text":"allowing for more complex experiments (such as varying the effects of gravity).","type":"text"},{"text":" ","type":"text"},{"text":"This environment involves a cart that can moved linearly, with a pole fixed on it","type":"text"},{"text":" ","type":"text"},{"text":"at one end and having another end free. The cart can be pushed left or right, and the","type":"text"},{"text":" ","type":"text"},{"text":"goal is to balance the pole on the top of the cart by applying forces on the cart.","type":"text"}],"type":"paragraph"},{"anchor":"Action-Space","level":3,"type":"heading","text":"Action Space"},{"inlineContent":[{"text":"The agent take a 1-element vector for actions.","type":"text"},{"text":" ","type":"text"},{"text":"The action space is a continuous ","type":"text"},{"code":"(action)","type":"codeVoice"},{"text":" in ","type":"text"},{"code":"[-3, 3]","type":"codeVoice"},{"text":", where ","type":"text"},{"code":"action","type":"codeVoice"},{"text":" represents","type":"text"},{"text":" ","type":"text"},{"text":"the numerical force applied to the cart (with magnitude representing the amount of","type":"text"},{"text":" ","type":"text"},{"text":"force and sign representing the direction)","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Force applied on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Force (N)","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Observation-Space","level":3,"type":"heading","text":"Observation Space"},{"inlineContent":[{"text":"The state space consists of positional values of different body parts of","type":"text"},{"text":" ","type":"text"},{"text":"the pendulum system, followed by the velocities of those individual parts (their derivatives)","type":"text"},{"text":" ","type":"text"},{"text":"with all the positions ordered before all the velocities.","type":"text"},{"text":" ","type":"text"},{"text":"The observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(4,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Observation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"position of the cart along the linear surface","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slider"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"slide"}],"type":"paragraph"}],[{"inlineContent":[{"text":"position (m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"vertical angle of the pole on the cart","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angle (rad)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"linear velocity of the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slider","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"velocity (m\/s)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"angular velocity of the pole on the cart"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"anglular velocity (rad\/s)","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Rewards","level":3,"type":"heading","text":"Rewards"},{"inlineContent":[{"type":"text","text":"The goal is to make the inverted pendulum stand upright (within a certain angle limit)"},{"type":"text","text":" "},{"type":"text","text":"as long as possible - as such a reward of +1 is awarded for each timestep that"},{"type":"text","text":" "},{"type":"text","text":"the pole is upright."}],"type":"paragraph"},{"anchor":"Starting-State","level":3,"type":"heading","text":"Starting State"},{"inlineContent":[{"text":"All observations start in state","type":"text"},{"text":" ","type":"text"},{"text":"(0.0, 0.0, 0.0, 0.0) with a uniform noise in the range","type":"text"},{"text":" ","type":"text"},{"text":"of [-0.01, 0.01] added to the values for stochasticity.","type":"text"}],"type":"paragraph"},{"anchor":"Episode-End","level":3,"type":"heading","text":"Episode End"},{"inlineContent":[{"text":"The episode ends when any of the following happens:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Truncation: The episode duration reaches 1000 timesteps."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Termination: Any of the state space values is no longer finite."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Termination: The absolutely value of the vertical angle between the pole and the cart is greater than 0.2 radian.","type":"text"}]}]}],"type":"orderedList"},{"anchor":"Arguments","level":3,"type":"heading","text":"Arguments"},{"inlineContent":[{"text":"No additional arguments are currently supported.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["env = gym.make('InvertedPendulum-v4')"]},{"inlineContent":[{"type":"text","text":"There is no v3 for InvertedPendulum, unlike the robot environments where a"},{"type":"text","text":" "},{"type":"text","text":"v3 and beyond take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}],"type":"paragraph"},{"anchor":"Version-History","level":3,"type":"heading","text":"Version History"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks (including inverted pendulum)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","navigatorTitle":[{"text":"Env","kind":"identifier"}],"abstract":[],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Env","kind":"identifier"}],"title":"Env","type":"topic","url":"\/documentation\/gym\/env","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/model":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"preciseIdentifier":"s:6MuJoCo7MjModelV","kind":"typeIdentifier","text":"MjModel"}],"title":"model","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/model","type":"topic","url":"\/documentation\/gym\/invertedpendulum\/model","role":"symbol","kind":"symbol","abstract":[]},"https://ieeexplore.ieee.org/document/6313077":{"title":"“Neuronlike adaptive elements that can solve difficult learning control problems”","identifier":"https:\/\/ieeexplore.ieee.org\/document\/6313077","type":"link","url":"https:\/\/ieeexplore.ieee.org\/document\/6313077","titleInlineContent":[{"type":"text","text":"“Neuronlike adaptive elements that can"},{"type":"text","text":" "},{"type":"text","text":"solve difficult learning control problems”"}]},"doc://org.liuliu.s4nnc/documentation/Gym":{"url":"\/documentation\/gym","kind":"symbol","abstract":[],"role":"collection","type":"topic","title":"Gym","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum/data":{"title":"data","type":"topic","abstract":[],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum\/data","url":"\/documentation\/gym\/invertedpendulum\/data","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"s:6MuJoCo6MjDataV","kind":"typeIdentifier","text":"MjData"}]},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/gym\/mujocoenv","role":"symbol","title":"MuJoCoEnv","abstract":[],"navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/InvertedPendulum":{"type":"topic","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InvertedPendulum"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/InvertedPendulum","navigatorTitle":[{"text":"InvertedPe