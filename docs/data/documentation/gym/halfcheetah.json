{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/HalfCheetah\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/HalfCheetah\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/HalfCheetah\/model"]},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/HalfCheetah\/Env-Implementations"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To"}],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/HalfCheetah","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"HalfCheetah"}],"platforms":["Linux"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Description","level":3,"anchor":"Description"},{"type":"paragraph","inlineContent":[{"text":"This environment is based on the work by P. Wawrzyński in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"http:\/\/staff.elka.pw.edu.pl\/~pwawrzyn\/pub-s\/0812_LSCLRR.pdf","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The HalfCheetah is a 2-dimensional robot consisting of 9 links and 8","type":"text"},{"text":" ","type":"text"},{"text":"joints connecting them (including two paws). The goal is to apply a torque","type":"text"},{"text":" ","type":"text"},{"text":"on the joints to make the cheetah run forward (right) as fast as possible,","type":"text"},{"text":" ","type":"text"},{"text":"with a positive reward allocated based on the distance moved forward and a","type":"text"},{"text":" ","type":"text"},{"text":"negative reward allocated for moving backward. The torso and head of the","type":"text"},{"text":" ","type":"text"},{"text":"cheetah are fixed, and the torque can only be applied on the other 6 joints","type":"text"},{"text":" ","type":"text"},{"text":"over the front and back thighs (connecting to the torso), shins","type":"text"},{"text":" ","type":"text"},{"text":"(connecting to the thighs) and feet (connecting to the shins).","type":"text"}]},{"type":"heading","text":"Action Space","level":3,"anchor":"Action-Space"},{"type":"paragraph","inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (6,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied between ","type":"text"},{"inlineContent":[{"type":"text","text":"links"}],"type":"emphasis"},{"text":".","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the back thigh rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"bthigh","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the back shin rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"bshin"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the back foot rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"bfoot"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the front thigh rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"fthigh","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the front shin rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"fshin","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the front foot rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"ffoot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]]]},{"type":"heading","text":"Observation Space","level":3,"anchor":"Observation-Space"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Observations consist of positional values of different body parts of the"},{"type":"text","text":" "},{"type":"text","text":"cheetah, followed by the velocities of those individual parts (their derivatives) with all the positions ordered before all the velocities."},{"type":"text","text":" "},{"type":"text","text":"By default, observations do not include the x-coordinate of the cheetah’s center of mass. It may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"In that case, the observation space will have 18 dimensions where the first dimension"},{"type":"text","text":" "},{"type":"text","text":"represents the x-coordinate of the cheetah’s center of mass."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"type":"text","text":" was set to true or false, the x-coordinate"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"code":"info","type":"codeVoice"},{"type":"text","text":" with key "},{"code":"\"x_position\"","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"However, by default, the observation is a "},{"code":"ndarray","type":"codeVoice"},{"type":"text","text":" with shape "},{"code":"(17,)","type":"codeVoice"},{"type":"text","text":" where the elements correspond to the following:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Observation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"z-coordinate of the front tip"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"rootz","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"position (m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angle of the front tip","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"rooty","type":"text"}],"type":"paragraph"}],[{"inlineConten