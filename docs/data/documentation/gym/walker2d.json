top. It may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"In that case, the observation space will have 18 dimensions where the first dimension"},{"type":"text","text":" "},{"type":"text","text":"represent the x-coordinates of the top of the walker."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x-coordinate"},{"type":"text","text":" "},{"type":"text","text":"of the top will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with key "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"By default, observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(17,)"},{"type":"text","text":" where the elements correspond to the following:"}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Observation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"z-coordinate of the top (height of hopper)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"