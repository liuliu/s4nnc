{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/gym\/walker2d"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D\/init(forwardRewardWeight:ctrlCostWeight:healthyReward:terminateWhenUnhealthy:healthyZRange:healthyAngleRange:resetNoiseScale:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D\/model"]},{"title":"Default Implementations","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D\/Env-Implementations"],"generated":true}],"metadata":{"externalID":"s:3Gym8Walker2DC","title":"Walker2D","symbolKind":"class","role":"symbol","roleHeading":"Class","modules":[{"name":"Gym"}],"navigatorTitle":[{"kind":"identifier","text":"Walker2D"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Walker2D"}]},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Walker2D"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"Description","text":"Description","level":3},{"inlineContent":[{"type":"text","text":"This environment builds on the hopper environment based on the work done by Erez, Tassa, and Todorov"},{"type":"text","text":" "},{"type":"text","text":"in "},{"identifier":"http:\/\/www.roboticsproceedings.org\/rss07\/p10.pdf","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"by adding another set of legs making it possible for the robot to walker forward instead of"},{"type":"text","text":" "},{"type":"text","text":"hop. Like other Mujoco environments, this environment aims to increase the number of independent state"},{"type":"text","text":" "},{"type":"text","text":"and control variables as compared to the classic control environments. The walker is a"},{"type":"text","text":" "},{"type":"text","text":"two-dimensional two-legged figure that consist of four main body parts - a single torso at the top"},{"type":"text","text":" "},{"type":"text","text":"(with the two legs splitting after the torso), two thighs in the middle below the torso, two legs"},{"type":"text","text":" "},{"type":"text","text":"in the bottom below the thighs, and two feet attached to the legs on which the entire body rests."},{"type":"text","text":" "},{"type":"text","text":"The goal is to make coordinate both sets of feet, legs, and thighs to move in the forward (right)"},{"type":"text","text":" "},{"type":"text","text":"direction by applying torques on the six hinges connecting the six body parts."}],"type":"paragraph"},{"type":"heading","anchor":"Action-Space","text":"Action Space","level":3},{"inlineContent":[{"type":"text","text":"The action space is a "},{"code":"Box(-1, 1, (6,), float32)","type":"codeVoice"},{"type":"text","text":". An action represents the torques applied at the hinge joints."}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the thigh rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"thigh_joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the leg rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"leg_joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the foot rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"foot_joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the left thigh rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"thigh_left_joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"4","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the left leg rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"leg_left_joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"5","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the left foot rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"foot_left_joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","anchor":"Observation-Space","text":"Observation Space","level":3},{"inlineContent":[{"type":"text","text":"Observations consist of positional values of different body parts of the walker,"},{"type":"text","text":" "},{"type":"text","text":"followed by the velocities of those individual parts (their derivatives) with all the positions ordered before all the velocities."},{"type":"text","text":" "},{"type":"text","text":"By default, observations do not include the x-coordinate of the top. It may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"In that case, the observation space will have 18 dimensions where the first dimension"},{"type":"text","text":" "},{"type":"text","text":"represent the x-coordinates of the top of the walker."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x-coordinate"},{"type":"text","text":" "},{"type":"text","text":"of the top will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with key "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"By default, observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(17,)"},{"type":"text","text":" where the elements correspond to the following:"}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Observation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"z-coordinate of the top (height of hopper)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"rootz (torso)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"slide","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"position (m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"angle of the top"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-Inf"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Inf","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"rooty (torso)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"angle (rad)","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle of the thigh joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"thigh_joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle of the leg joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"leg_joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"4"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle of the foot joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Inf"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"foot_joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"5","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle of the left thigh joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"thigh_left_joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle (rad)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"6","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"angle of the left leg joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-Inf"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"leg_left_joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"7","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle of the left foot joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Inf","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"foot_left_joint","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"angle (rad)","type":"text"}]}]],[[{"inlineContent":[{"text":"8","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"velocity of the x-coordinate of the top"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-Inf","type":"text"}],"type":"