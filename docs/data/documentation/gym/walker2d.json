 versions release (1.0.0)","type":"text"}]}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/walker2d"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Walker2D/model":{"title":"model","url":"\/documentation\/gym\/walker2d\/model","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV"}],"role":"symbol","abstract":[],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D\/model"},"doc://org.liuliu.s4nnc/documentation/Gym/Walker2D":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Walker2D"}],"url":"\/documentation\/gym\/walker2d","kind":"symbol","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Walker2D","abstract":[],"title":"Walker2D","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Walker2D"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"abstract":[],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","title":"Env","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"navigatorTitle":[{"text":"Env","kind":"identifier"}],"url":"\/documentation\/gym\/env","role":"symbol","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym":{"abstract":[],"title":"Gym","url":"\/documentation\/gym","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","kind":"symbol","role":"collection","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Walker2D/init(forwardRewardWeight:ctrlCostWeight:healthyReward:terminateWhenUnhealthy:healthyZRange:healthyAngleRange:resetNoiseScale:)":{"url":"\/documentation\/gym\/walker2d\/init(forwardrewardweight: