{"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"s:3Gym7SwimmerC","title":"Swimmer","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"roleHeading":"Class","modules":[{"name":"Gym"}],"symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"role":"symbol"},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"]}],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"Description","text":"Description","level":3},{"type":"paragraph","inlineContent":[{"text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"reference","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The environment aims to increase the number of independent state and control","type":"text"},{"text":" ","type":"text"},{"text":"variables as compared to the classic control environments. The swimmers","type":"text"},{"text":" ","type":"text"},{"text":"consist of three or more segments (’","type":"text"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"text":"links","type":"text"}]}]},{"text":"’) and one less articulation","type":"text"},{"text":" ","type":"text"},{"text":"joints (’","type":"text"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"text":"rotors","type":"text"}]}]},{"text":"’) - one rotor joint connecting exactly two links to","type":"text"},{"text":" ","type":"text"},{"text":"form a linear chain. The swimmer is suspended in a two dimensional pool and","type":"text"},{"text":" ","type":"text"},{"text":"always starts in the same position (subject to some deviation drawn from an","type":"text"},{"text":" ","type":"text"},{"text":"uniform distribution), and the goal is to move as fast as possible towards","type":"text"},{"text":" ","type":"text"},{"text":"the right by applying torque on the rotors and using the fluids friction.","type":"text"}]},{"type":"heading","anchor":"Notes","text":"Notes","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":": number of body parts","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":": length of part "},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" ("},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" ∈ {1…n})"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" = 3, "},{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}]}]}],"type":"unorderedList"},{"type":"heading","anchor":"Action-Space","text":"Action Space","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"type":"emphasis","inlineContent":[{"text":"links","type":"text"}]}]},{"type":"table","rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Joint"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"motor1_rot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"motor2_rot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","anchor":"Observation-Space","text":"Observation Space","level":3},{"type":"paragraph","inlineContent":[{"text":"By default, observations consists of:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"text":" with respect to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"text":" axis","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"text":" ","type":"text"},{"text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may","type":"text"},{"text":" ","type":"text"},{"text":"be included by passing ","type":"text"},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"text":" during construction.","type":"text"},{"text":" ","type":"text"},{"text":"Then, the observation space will have 10 dimensions where the first two dimensions","type":"text"},{"text":" ","type":"text"},{"text":"represent the x- and y-coordinates of the front tip.","type":"text"},{"text":" ","type":"text"},{"text":"Regardless of whether ","type":"text"},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"will be returned in ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" with keys ","type":"text"},{"code":"\"x_position\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"y_position\"","type":"codeVoice"},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"By default, the observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(8,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"},{"text":" ","type":"text"},{"text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |","type":"text"},{"text":" ","type":"text"},{"text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |","type":"text"},{"text":" ","type":"text"},{"text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Rewards","text":"Rewards","level":3},{"type":"paragraph","inlineContent":[{"text":"The reward consists of two parts:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"emphasis","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}]},{"type":"text","text":". "},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"type":"emphasis","inlineContent":[{"text":"dt = 4 * 0.01 = 0.04","type":"text"}]},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"type":"text","text":": A cost for penalising the swimmer if it takes"},{"type":"text","text":" "},{"type":"text","text":"actions that are too large. It is measured as "},{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"type":"text","text":" where "},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"type":"text","text":" is a parameter set for the"},{"type":"text","text":" "},{"type":"text","text":"control and has a default value of 1e-4"},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"="}],"type":"emphasis"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"forward_reward - ctrl_cost"}],"type":"emphasis"},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Starting-State","text":"Starting State","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":", "},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":"] is added to the initial state for stochasticity."}]},{"type":"heading","anchor":"Episode-End","text":"Episode End","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}]},{"type":"heading","anchor":"Arguments","text":"Arguments","level":3},{"type":"paragraph","inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}]},{"type":"codeListing","code":["gym.make('Swimmer-v4')"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"type":"codeListing","code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"syntax":null},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"xml_file"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"str","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"1.0","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"inlineContent":[{"text":"forward_reward","type":"text"}],"type":"emphasis"},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1e-4"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0.1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"bool","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}]}]]],"header":"row"},{"type":"heading","anchor":"Version-History","text":"Version History","level":3},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}],"type":"unorderedList"}]}],"kind":"symbol","sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"]},{"title":"Default Implementations","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/swimmer"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"navigatorTitle":[{"text":"Env","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"Env","kind":"identifier"}],"role":"symbol","abstract":[],"title":"Env","type":"topic","url":"\/documentation\/gym\/env","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"link","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","titleInlineContent":[{"type":"text","text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"abstract":[],"kind":"symbol","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","role":"symbol","url":"\/documentation\/gym\/swimmer\/data","title":"data","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo6MjDataV","text":"MjData"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"url":"\/documentation\/gym\/swimmer","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","title":"Swimmer","abstract":[],"kind":"symbol","role":"symbol","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","title":"model","type":"topic","url":"\/documentation\/gym\/swimmer\/model","kind":"symbol","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"model","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:6MuJoCo7MjModelV","text":"MjModel","kind":"typeIdentifier"}]},"doc://org.liuliu.s4nnc/documentation/Gym":{"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","title":"Gym","role":"collection","abstract":[],"url":"\/documentation\/gym","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","kind":"article","abstract":[],"type":"topic","url":"\/documentation\/gym\/swimmer\/env-implementations","role":"collectionGroup","title":"Env Implementations"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"type":"topic","title":"MuJoCoEnv","abstract":[],"role":"symbol","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MuJoCoEnv"}],"url":"\/documentation\/gym\/mujocoenv"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"role":"symbol","kind":"symbol"