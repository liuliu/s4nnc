er":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","type":"topic","title":"data","role":"symbol","abstract":[]},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MuJoCoEnv","url":"\/documentation\/gym\/mujocoenv","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Swimmer","url":"\/documentation\/gym\/swimmer","role":"symbol"}}}