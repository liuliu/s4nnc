{"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations","generated":true}],"kind":"symbol","variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Description","type":"heading","level":3,"anchor":"Description"},{"inlineContent":[{"text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The environment aims to increase the number of independent state and control","type":"text"},{"text":" ","type":"text"},{"text":"variables as compared to the classic control environments. The swimmers","type":"text"},{"text":" ","type":"text"},{"text":"consist of three or more segments (’","type":"text"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"links"}]}],"type":"emphasis"},{"text":"’) and one less articulation","type":"text"},{"text":" ","type":"text"},{"text":"joints (’","type":"text"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"rotors","type":"text"}]}],"type":"emphasis"},{"text":"’) - one rotor joint connecting exactly two links to","type":"text"},{"text":" ","type":"text"},{"text":"form a linear chain. The swimmer is suspended in a two dimensional pool and","type":"text"},{"text":" ","type":"text"},{"text":"always starts in the same position (subject to some deviation drawn from an","type":"text"},{"text":" ","type":"text"},{"text":"uniform distribution), and the goal is to move as fast as possible towards","type":"text"},{"text":" ","type":"text"},{"text":"the right by applying torque on the rotors and using the fluids friction.","type":"text"}],"type":"paragraph"},{"text":"Notes","type":"heading","level":3,"anchor":"Notes"},{"inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":": number of body parts","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"m","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":": length of part "},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":": viscous-friction coefficient","type":"text"},{"text":" ","type":"text"},{"text":"While the default environment has ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" = 3, ","type":"text"},{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":" = 0.1,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the","type":"text"},{"text":" ","type":"text"},{"text":"number of links, or to tweak any of the parameters.","type":"text"}]}]}]},{"text":"Action Space","type":"heading","level":3,"anchor":"Action-Space"},{"inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"inlineContent":[{"text":"links","type":"text"}],"type":"emphasis"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Action","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor1_rot"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"motor2_rot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]]]},{"text":"Observation Space","type":"heading","level":3,"anchor":"Observation-Space"},{"inlineContent":[{"type":"text","text":"By default, observations consists of:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":": angle of part "},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" with respect to the "},{"type":"emphasis","inlineContent":[{"text":"x","type":"text"}]},{"type":"text","text":" axis"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"code":"info","type":"codeVoice"},{"type":"text","text":" with keys "},{"code":"\"x_position\"","type":"codeVoice"},{"type":"text","text":" and "},{"code":"\"y_position\"","type":"codeVoice"},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"code":"ndarray","type":"codeVoice"},{"type":"text","text":" with shape "},{"code":"(8,)","type":"codeVoice"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}],"type":"paragraph"}]}]},{"text":"Rewards","type":"heading","level":3,"anchor":"Rewards"},{"inlineContent":[{"type":"text","text":"The reward consists of two parts:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"},{"text":" * (x-coordinate before action - x-coordinate after action)\/dt","type":"text"}]},{"type":"text","text":". "},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"type":"emphasis","inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}]},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"ctrl_cost","type":"text"}]},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}]},{"text":" where ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"="}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}]},{"text":" and ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" will also contain the individual reward terms","type":"text"}]}]}]},{"text":"Starting State","type":"heading","level":3,"anchor":"Starting-State"},{"inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":", "},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":"] is added to the initial state for stochasticity."}],"type":"paragraph"},{"text":"Episode End","type":"heading","level":3,"anchor":"Episode-End"},{"inlineContent":[{"text":"The episode truncates when the episode length is greater than 1000.","type":"text"}],"type":"paragraph"},{"text":"Arguments","type":"heading","level":3,"anchor":"Arguments"},{"inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}],"type":"paragraph"},{"type":"codeListing","code":["gym.make('Swimmer-v4')"],"syntax":null},{"inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"syntax":null},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"xml_file"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"str","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}]}],[{"type":"paragraph","inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"1.0","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"1e-4","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0.1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"bool"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}]}]]]},{"text":"Version History","type":"heading","level":3,"anchor":"Version-History"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}]}],"kind":"content"}],"metadata":{"symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"externalID":"s:3Gym7SwimmerC","title":"Swimmer","modules":[{"name":"Gym"}],"navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"role":"symbol","roleHeading":"Class"},"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"abstract":[],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forwardRewardWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ctrlCostWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"resetNoiseScale","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"kind":"symbol","role":"symbol","url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"abstract":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjData","preciseIdentifier":"s:6MuJoCo6MjDataV","kind":"typeIdentifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/gym\/swimmer\/data","title":"data","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"kind":"symbol","abstract":[],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"role":"symbol","url":"\/documentation\/gym\/swimmer","title":"Swimmer"},"doc://org.liuliu.s4nnc/documentation/Gym":{"url":"\/documentation\/gym","type":"topic","title":"Gym","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","abstract":[],"role":"collection"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","abstract":[],"role":"symbol","type":"topic","title":"MuJoCoEnv","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"MuJoCoEnv","kind":"identifier"}],"navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"url":"\/documentation\/gym\/mujocoenv","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"url":"\/documentation\/gym\/env","navigatorTitle":[{"text":"Env","kind":"identifier"}],"title":"Env","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","abstract":[],"type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Env","kind":"identifier"}],"kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"abstract":[],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"model","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV","kind":"