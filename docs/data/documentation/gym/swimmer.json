":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/gym\/swimmer\/env-implementations","title":"Env Implementations","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"type":"link","url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","titleInlineContent":[{"type":"text","text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}],"title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}}}