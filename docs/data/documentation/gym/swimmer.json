{"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"Gym"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"role":"symbol","externalID":"s:3Gym7SwimmerC","symbolKind":"class","roleHeading":"Class","title":"Swimmer","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}]}],"kind":"declarations"},{"content":[{"level":3,"type":"heading","anchor":"Description","text":"Description"},{"type":"paragraph","inlineContent":[{"text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The environment aims to increase the number of independent state and control","type":"text"},{"text":" ","type":"text"},{"text":"variables as compared to the classic control environments. The swimmers","type":"text"},{"text":" ","type":"text"},{"text":"consist of three or more segments (’","type":"text"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"links"}],"type":"strong"}],"type":"emphasis"},{"text":"’) and one less articulation","type":"text"},{"text":" ","type":"text"},{"text":"joints (’","type":"text"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"rotors"}],"type":"strong"}],"type":"emphasis"},{"text":"’) - one rotor joint connecting exactly two links to","type":"text"},{"text":" ","type":"text"},{"text":"form a linear chain. The swimmer is suspended in a two dimensional pool and","type":"text"},{"text":" ","type":"text"},{"text":"always starts in the same position (subject to some deviation drawn from an","type":"text"},{"text":" ","type":"text"},{"text":"uniform distribution), and the goal is to move as fast as possible towards","type":"text"},{"text":" ","type":"text"},{"text":"the right by applying torque on the rotors and using the fluids friction.","type":"text"}]},{"level":3,"type":"heading","anchor":"Notes","text":"Notes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"type":"text","text":": number of body parts"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":": length of part "},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" ("},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"k","type":"text"}]},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" = 3, "},{"type":"emphasis","inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}]},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"k"}]},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","anchor":"Action-Space","text":"Action Space"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]}]},{"rows":[[[{"inlineContent":[{"text":"Num","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Action","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor1_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the second rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"motor2_rot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"level":3,"type":"heading","anchor":"Observation-Space","text":"Observation Space"},{"type":"paragraph","inlineContent":[{"text":"By default, observations consists of:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"text":" with respect to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"text":" axis","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"text":" ","type":"text"},{"text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may","type":"text"},{"text":" ","type":"text"},{"text":"be included by passing ","type":"text"},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"text":" during construction.","type":"text"},{"text":" ","type":"text"},{"text":"Then, the observation space will have 10 dimensions where the first two dimensions","type":"text"},{"text":" ","type":"text"},{"text":"represent the x- and y-coordinates of the front tip.","type":"text"},{"text":" ","type":"text"},{"text":"Regardless of whether ","type":"text"},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"will be returned in ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" with keys ","type":"text"},{"code":"\"x_position\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"y_position\"","type":"codeVoice"},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"By default, the observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(8,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"},{"text":" ","type":"text"},{"text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |","type":"text"},{"text":" ","type":"text"},{"text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |","type":"text"},{"text":" ","type":"text"},{"text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"type":"heading","anchor":"Rewards","text":"Rewards"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reward consists of two parts:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}],"type":"emphasis"},{"type":"text","text":". "},{"inlineContent":[{"text":"dt","type":"text"}],"type":"emphasis"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}],"type":"emphasis"},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"text":" where ","type":"text"},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"="}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"forward_reward - ctrl_cost"}],"type":"emphasis"},{"text":" and ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" will also contain the individual reward terms","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"type":"heading","anchor":"Starting-State","text":"Starting State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":", "},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":"] is added to the initial state for stochasticity."}]},{"level":3,"type":"heading","anchor":"Episode-End","text":"Episode End"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}]},{"level":3,"type":"heading","anchor":"Arguments","text":"Arguments"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}]},{"type":"codeListing","syntax":null,"code":["gym.make('Swimmer-v4')"]},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"type":"codeListing","syntax":null,"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"xml_file","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"swimmer.xml\"","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1.0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"1e-4","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"0.1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"bool"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}]}]]],"type":"table","header":"row"},{"level":3,"type":"heading","anchor":"Version-History","text":"Version History"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}]}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/swimmer"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forwardRewardWeight"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ctrlCostWeight"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"resetNoiseScale"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","abstract":[],"url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","role":"symbol","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym":{"url":"\/documentation\/gym","kind":"symbol","type":"topic","title":"Gym","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","role":"collection","abstract":[]},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"type":"topic","role":"collectionGroup","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","abstract":[],"url":"\/documentation\/gym\/swimmer\/env-implementations","kind":"article","title":"Env Implementations"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","url":"\/documentation\/gym\/mujocoenv","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"abstract":[],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MuJoCoEnv","kind":"identifier"}],"title":"MuJoCoEnv"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"link","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","titleInlineContent":[{"text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"text"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","title":"Env","kind":"symbol","navigatorTitle":[{"text":"Env","kind":"identifier"}],"url":"\/documentation\/gym\/env","role":"symbol","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"s:6MuJoCo6MjDataV","text":"MjData","kind":"typeIdentifier"}],"title":"data","kind":"symbol","url":"\/documentation\/gym\/swimmer\/data","identifier":"doc:\/\/org.liuli