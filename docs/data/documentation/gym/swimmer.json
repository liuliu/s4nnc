{"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations"}],"metadata":{"navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"role":"symbol","externalID":"s:3Gym7SwimmerC","symbolKind":"class","roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"title":"Swimmer","modules":[{"name":"Gym"}]},"variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"platforms":["Linux"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Description","level":3,"type":"heading","anchor":"Description"},{"type":"paragraph","inlineContent":[{"text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The environment aims to increase the number of independent state and control","type":"text"},{"text":" ","type":"text"},{"text":"variables as compared to the classic control environments. The swimmers","type":"text"},{"text":" ","type":"text"},{"text":"consist of three or more segments (’","type":"text"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"links"}]}]},{"text":"’) and one less articulation","type":"text"},{"text":" ","type":"text"},{"text":"joints (’","type":"text"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"rotors"}]}]},{"text":"’) - one rotor joint connecting exactly two links to","type":"text"},{"text":" ","type":"text"},{"text":"form a linear chain. The swimmer is suspended in a two dimensional pool and","type":"text"},{"text":" ","type":"text"},{"text":"always starts in the same position (subject to some deviation drawn from an","type":"text"},{"text":" ","type":"text"},{"text":"uniform distribution), and the goal is to move as fast as possible towards","type":"text"},{"text":" ","type":"text"},{"text":"the right by applying torque on the rotors and using the fluids friction.","type":"text"}]},{"text":"Notes","level":3,"type":"heading","anchor":"Notes"},{"type":"paragraph","inlineContent":[{"text":"The problem parameters are:","type":"text"},{"text":" ","type":"text"},{"text":"Problem parameters:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":": number of body parts"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}]},{"text":": mass of part ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"text":" (","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"text":" ∈ {1…n})","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":": length of part "},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" ("},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"text":": viscous-friction coefficient","type":"text"},{"text":" ","type":"text"},{"text":"While the default environment has ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" = 3, ","type":"text"},{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":" = 0.1,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the","type":"text"},{"text":" ","type":"text"},{"text":"number of links, or to tweak any of the parameters.","type":"text"}],"type":"paragraph"}]}]},{"text":"Action Space","level":3,"type":"heading","anchor":"Action-Space"},{"type":"paragraph","inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (2,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied between ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor1_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"motor2_rot","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"hinge"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"text":"Observation Space","level":3,"type":"heading","anchor":"Observation-Space"},{"type":"paragraph","inlineContent":[{"text":"By default, observations consists of:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" with respect to the ","type":"text"},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"text":" axis","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":"’: its derivative with respect to time (angular velocity)"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with keys "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"y_position\""},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(8,)"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}]}]}]},{"text":"Rewards","level":3,"type":"heading","anchor":"Rewards"},{"type":"paragraph","inlineContent":[{"text":"The reward consists of two parts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"emphasis","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}]},{"type":"text","text":". "},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"type":"emphasis","inlineContent":[{"text":"dt = 4 * 0.01 = 0.04","type":"text"}]},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":": A cost for penalising the swimmer if it takes"},{"type":"text","text":" "},{"type":"text","text":"actions that are too large. It is measured as "},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"text":" *","type":"text"},{"text":" ","type":"text"},{"text":"sum(action","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}]},{"type":"text","text":" where "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}]},{"type":"text","text":" is a parameter set for the"},{"type":"text","text":" "},{"type":"text","text":"control and has a default value of 1e-4"},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"=","type":"text"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}]},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms"}]}]}]},{"text":"Starting State","level":3,"type":"heading","anchor":"Starting-State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":", "},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":"] is added to the initial state for stochasticity."}]},{"text":"Episode End","level":3,"type":"heading","anchor":"Episode-End"},{"type":"paragraph","inlineContent":[{"text":"The episode truncates when the episode length is greater than 1000.","type":"text"}]},{"text":"Arguments","level":3,"type":"heading","anchor":"Arguments"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}]},{"type":"codeListing","code":["gym.make('Swimmer-v4')"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"type":"codeListing","code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"syntax":null},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"xml_file"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"\"swimmer.xml\"","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1.0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1e-4"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"bool"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"text":"Version History","level":3,"type":"heading","anchor":"Version-History"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}]}]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"url":"\/documentation\/gym\/swimmer","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"type":"topic","kind":"symbol","title":"Swimmer","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"url":"\/documentation\/gym\/env","navigatorTitle":[{"kind":"identifier","text":"Env"}],"type":"topic","kind":"symbol","title":"Env","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MuJoCoEnv"}],"url":"\/documentation\/gym\/mujocoenv","navigatorTitle":[{"kind":"identifier","text":"MuJoCoEnv"}],"type":"topic","kind":"symbol","title":"MuJoCoEnv","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"url":"\/documentation\/gym\/swimmer\/env-implementations","type":"topic","kind":"article","title":"Env Implementations","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","role":"collectionGroup"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjData","preciseIdentifier":"s:6MuJoCo6MjDataV"}],"abstract":[],"url":"\/documentation\/gym\/swimmer\/data","title":"data","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"type":"topic","kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forwardRewardWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":", ","kind":"text"},{"text":"ctrlCostWeight","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"resetNoiseScale"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","abstract":[],"role":"symbol","title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"type":"topic","url":"\/documentation\/gym\/swimmer\/model","kind":"symbol","abstract":[],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"model","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV","kind":"typeIdentifier"}],"role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","title":"model"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","titleInlineContent":[{"text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"text"}],"url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"link","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},"doc://org.liuliu.s4nnc/documentation/Gym":{"abstract":[],"title":"Gym","url":"\/documentation\/gym","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","role":"collection","kind":"symbol"}}}