{"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"metadata":{"externalID":"s:3Gym7SwimmerC","symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"modules":[{"name":"Gym"}],"title":"Swimmer","role":"symbol","roleHeading":"Class"},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}]}]},{"content":[{"anchor":"Description","text":"Description","level":3,"type":"heading"},{"inlineContent":[{"text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The environment aims to increase the number of independent state and control","type":"text"},{"text":" ","type":"text"},{"text":"variables as compared to the classic control environments. The swimmers","type":"text"},{"text":" ","type":"text"},{"text":"consist of three or more segments (’","type":"text"},{"inlineContent":[{"inlineContent":[{"text":"links","type":"text"}],"type":"strong"}],"type":"emphasis"},{"text":"’) and one less articulation","type":"text"},{"text":" ","type":"text"},{"text":"joints (’","type":"text"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"rotors"}],"type":"strong"}],"type":"emphasis"},{"text":"’) - one rotor joint connecting exactly two links to","type":"text"},{"text":" ","type":"text"},{"text":"form a linear chain. The swimmer is suspended in a two dimensional pool and","type":"text"},{"text":" ","type":"text"},{"text":"always starts in the same position (subject to some deviation drawn from an","type":"text"},{"text":" ","type":"text"},{"text":"uniform distribution), and the goal is to move as fast as possible towards","type":"text"},{"text":" ","type":"text"},{"text":"the right by applying torque on the rotors and using the fluids friction.","type":"text"}],"type":"paragraph"},{"anchor":"Notes","text":"Notes","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":": number of body parts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}]},{"type":"text","text":": mass of part "},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": length of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"k"}]},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" = 3, "},{"type":"emphasis","inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"k"}]},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}]}]}],"type":"unorderedList"},{"anchor":"Action-Space","text":"Action Space","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The action space is a "},{"code":"Box(-1, 1, (2,), float32)","type":"codeVoice"},{"type":"text","text":". An action represents the torques applied between "},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the first rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor1_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor2_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]]],"type":"table","header":"row"},{"anchor":"Observation-Space","text":"Observation Space","level":3,"type":"heading"},{"inlineContent":[{"text":"By default, observations consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":": angle of part "},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" with respect to the "},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"type":"text","text":" axis"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":"’: its derivative with respect to time (angular velocity)"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with keys "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"y_position\""},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(8,)"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}]}]}],"type":"unorderedList"},{"anchor":"Rewards","text":"Rewards","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The reward consists of two parts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"emphasis","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"text":" * (x-coordinate before action - x-coordinate after action)\/dt","type":"text"}]},{"type":"text","text":". "},{"type":"emphasis","inlineContent":[{"type":"text","text":"dt"}]},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"type":"emphasis","inlineContent":[{"text":"dt = 4 * 0.01 = 0.04","type":"text"}]},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":": A cost for penalising the swimmer if it takes"},{"type":"text","text":" "},{"type":"text","text":"actions that are too large. It is measured as "},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"text":" *","type":"text"},{"text":" ","type":"text"},{"text":"sum(action","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}]},{"type":"text","text":" where "},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]},{"type":"text","text":" is a parameter set for the"},{"type":"text","text":" "},{"type":"text","text":"control and has a default value of 1e-4"},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reward"}]}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"=","type":"text"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward - ctrl_cost"}]},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Starting-State","text":"Starting State","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":", "},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":"] is added to the initial state for stochasticity."}],"type":"paragraph"},{"anchor":"Episode-End","text":"Episode End","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}],"type":"paragraph"},{"anchor":"Arguments","text":"Arguments","level":3,"type":"heading"},{"inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["gym.make('Swimmer-v4')"]},{"inlineContent":[{"type":"text","text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type"}]}],[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"xml_file","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"str","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}]}],[{"type":"paragraph","inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"1.0","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"1e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"0.1","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"bool","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Version-History","text":"Version History","level":3,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments."}]}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/swimmer"]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"url":"\/documentation\/gym\/mujocoenv","kind":"symbol","abstract":[],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MuJoCoEnv"}],"title":"MuJoCoEnv","navigatorTitle":[{"kind":"identifier","text":"MuJoCoEnv"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"title":"Swimmer","kind":"symbol","url":"\/documentation\/gym\/swimmer","role":"symbol","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"type":"topic","abstract":[],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"doc://org.liuliu.s4nnc/documentation/Gym":{"kind":"symbol","role":"collection","abstract":[],"type":"topic","title":"Gym","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","url":"\/documentation\/gym"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"title":"Env","kind":"symbol","url":"\/documentation\/gym\/env","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Env"}],"type":"topic","abstract":[],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"role":"symbol","title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","kind":"symbol","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forwardRewardWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ctrlCostWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"resetNoiseScale","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjData","preciseIdentifier":"s:6MuJoCo6MjDataV"}],"type":"topic","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","role":"symbol","url":"\/documentation\/gym\/swimmer\/data","title":"data"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV"}],"type":"topic","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","role":"symbol","url":"\/documentation\/gym\/swimmer\/model","title":"model"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"type":"topic","kind":"article","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","title":"Env Implementations","abstract":[],"role":"collectionGroup","url":"\/documentation\/gym\/swimmer\/env-implementations"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"type":"link","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","titleInlineContent":[{"text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"text"}],"url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}}}