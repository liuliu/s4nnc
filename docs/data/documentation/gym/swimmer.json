{"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To"}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations","generated":true}],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Description","anchor":"Description","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"links","type":"text"}],"type":"strong"}]},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"rotors"}]}]},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}]},{"text":"Notes","anchor":"Notes","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The problem parameters are:","type":"text"},{"text":" ","type":"text"},{"text":"Problem parameters:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":": number of body parts","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"m","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":": mass of part "},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":": length of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":": viscous-friction coefficient","type":"text"},{"text":" ","type":"text"},{"text":"While the default environment has ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" = 3, ","type":"text"},{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":" = 0.1,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the","type":"text"},{"text":" ","type":"text"},{"text":"number of links, or to tweak any of the parameters.","type":"text"}],"type":"paragraph"}]}]},{"text":"Action Space","anchor":"Action-Space","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The action space is a ","type":"text"},{"code":"Box(-1, 1, (2,), float32)","type":"codeVoice"},{"text":". An action represents the torques applied between ","type":"text"},{"inlineContent":[{"text":"links","type":"text"}],"type":"emphasis"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Min"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"motor1_rot"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"torque (N m)"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the second rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"motor2_rot"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]]]},{"text":"Observation Space","anchor":"Observation-Space","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, observations consists of:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" with respect to the ","type":"text"},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"text":" axis","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"text":" ","type":"text"},{"text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may","type":"text"},{"text":" ","type":"text"},{"text":"be included by passing ","type":"text"},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"text":" during construction.","type":"text"},{"text":" ","type":"text"},{"text":"Then, the observation space will have 10 dimensions where the first two dimensions","type":"text"},{"text":" ","type":"text"},{"text":"represent the x- and y-coordinates of the front tip.","type":"text"},{"text":" ","type":"text"},{"text":"Regardless of whether ","type":"text"},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"will be returned in ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" with keys ","type":"text"},{"code":"\"x_position\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"y_position\"","type":"codeVoice"},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"By default, the observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(8,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"},{"text":" ","type":"text"},{"text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |","type":"text"},{"text":" ","type":"text"},{"text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |","type":"text"},{"text":" ","type":"text"},{"text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |","type":"text"}]}]}]},{"text":"Rewards","anchor":"Rewards","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reward consists of two parts:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"text":": A reward of moving forward which is measured","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"text":" * (x-coordinate before action - x-coordinate after action)\/dt","type":"text"}],"type":"emphasis"},{"text":". ","type":"text"},{"inlineContent":[{"text":"dt","type":"text"}],"type":"emphasis"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"the time between actions and is dependent on the frame_skip parameter","type":"text"},{"text":" ","type":"text"},{"text":"(default is 4), where the frametime is 0.01 - making the","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}],"type":"emphasis"},{"text":". This reward would be positive if the swimmer","type":"text"},{"text":" ","type":"text"},{"text":"swims right as desired.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}]},{"text":" where ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"reward","type":"text"}],"type":"strong"}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"="}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}]},{"text":" and ","type":"text"},{"type":"codeVoice","code":"info"},{"text":" will also contain the individual reward terms","type":"text"}]}]}]},{"text":"Starting State","anchor":"Starting-State","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":", "},{"type":"codeVoice","code":"reset_noise_scale"},{"type":"text","text":"] is added to the initial state for stochasticity."}]},{"text":"Episode End","anchor":"Episode-End","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}]},{"text":"Arguments","anchor":"Arguments","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}]},{"code":["gym.make('Swimmer-v4')"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc."}]},{"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"type":"codeListing","syntax":null},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Parameter","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Default","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"xml_file"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"str","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1.0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"1e-4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"bool","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}],"type":"paragraph"}]]]},{"text":"Version History","anchor":"Version-History","type":"heading","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}]}]}],"metadata":{"role":"symbol","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"title":"Swimmer","symbolKind":"class","modules":[{"name":"Gym"}],"roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"externalID":"s:3Gym7SwimmerC"},"variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"kind":"symbol","title":"Swimmer","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"type":"topic","abstract":[],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"url":"\/documentation\/gym\/swimmer","role":"symbol"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","titleInlineContent":[{"text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"text"}],"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"link"},"doc://org.liuliu.s4nnc/documentation/Gym":{"title":"Gym","role":"collection","abstract":[],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","url":"\/documentation\/gym","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"abstract":[],"kind":"symbol","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/G