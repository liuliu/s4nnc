","abstract":[],"title":"Gym","type":"topic","url":"\/documentation\/gym","role":"collection"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","abstract":[],"title":"Env","type":"topic","url":"\/documentation\/gym\/env","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"Env","kind":"identifier"}],"navigatorTitle":[{"text":"Env","kind":"identifier"}],"role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","title":"model","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV"}],"type":"topic","abstract":[],"url":"\/documentation\/gym\/swimmer\/model"}}}