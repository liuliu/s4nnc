kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"type":"topic","url":"\/documentation\/gym\/swimmer","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","title":"Swimmer","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"abstract":[],"kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"abstract":[],"url":"\/documentation\/gym\/env","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","role":"symbol","title":"Env","navigatorTitle":[{"kind":"identifier","text":"Env"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"type":"topic"}}}