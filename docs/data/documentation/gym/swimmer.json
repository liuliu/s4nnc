{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"symbolKind":"class","externalID":"s:3Gym7SwimmerC","modules":[{"name":"Gym"}],"role":"symbol","roleHeading":"Class","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"title":"Swimmer"},"relationshipsSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"sections":[],"identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"generated":true,"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"Description","level":3,"type":"heading","text":"Description"},{"inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"links"}]}],"type":"emphasis"},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"rotors"}],"type":"strong"}],"type":"emphasis"},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}],"type":"paragraph"},{"anchor":"Notes","level":3,"type":"heading","text":"Notes"},{"inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":": number of body parts"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":": length of part "},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"type":"text","text":" = 3, "},{"inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Action-Space","level":3,"type":"heading","text":"Action Space"},{"inlineContent":[{"text":"The action space is a ","type":"text"},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"text":". An action represents the torques applied between ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Min"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Torque applied on the first rotor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor1_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"torque (N m)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the second rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"motor2_rot"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"torque (N m)"}]}]]],"header":"row","type":"table"},{"anchor":"Observation-Space","level":3,"type":"heading","text":"Observation Space"},{"inlineContent":[{"text":"By default, observations consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"text":" with respect to the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"text":" axis","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":"’: its derivative with respect to time (angular velocity)"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with keys "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"y_position\""},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(8,)"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Rewards","level":3,"type":"heading","text":"Rewards"},{"inlineContent":[{"type":"text","text":"The reward consists of two parts:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"text":": A reward of moving forward which is measured","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}],"type":"emphasis"},{"text":". ","type":"text"},{"inlineContent":[{"text":"dt","type":"text"}],"type":"emphasis"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"the time between actions and is dependent on the frame_skip parameter","type":"text"},{"text":" ","type":"text"},{"text":"(default is 4), where the frametime is 0.01 - making the","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"inlineContent":[{"text":"dt = 4 * 0.01 = 0.04","type":"text"}],"type":"emphasis"},{"text":". This reward would be positive if the swimmer","type":"text"},{"text":" ","type":"text"},{"text":"swims right as desired.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"ctrl_cost","type":"text"}]},{"type":"text","text":": A cost for penalising the swimmer if it takes"},{"type":"text","text":" "},{"type":"text","text":"actions that are too large. It is measured as "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}]},{"type":"text","text":" where "},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}]},{"type":"text","text":" is a parameter set for the"},{"type":"text","text":" "},{"type":"text","text":"control and has a default value of 1e-4"},{"type":"text","text":" "},{"type":"text","text":"The total reward returned is "},{"type":"emphasis","inlineContent":[{"inlineContent":[{"type":"text","text":"reward"}],"type":"strong"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"=","type":"text"}]},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}]},{"type":"text","text":" and "},{"type":"codeVoice","code":"info"},{"type":"text","text":" will also contain the individual reward terms"}]}]}],"type":"unorderedList"},{"anchor":"Starting-State","level":3,"type":"heading","text":"Starting State"},{"inlineContent":[{"text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-","type":"text"},{"type":"codeVoice","code":"reset_noise_scale"},{"text":", ","type":"text"},{"type":"codeVoice","code":"reset_noise_scale"},{"text":"] is added to the initial state for stochasticity.","type":"text"}],"type":"paragraph"},{"anchor":"Episode-End","level":3,"type":"heading","text":"Episode End"},{"inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}],"type":"paragraph"},{"anchor":"Arguments","level":3,"type":"heading","text":"Arguments"},{"inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}],"type":"paragraph"},{"code":["gym.make('Swimmer-v4')"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"syntax":null,"type":"codeListing"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"xml_file"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"str"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}],"type":"paragraph"}],[{"inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"1.0","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"1e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"text":"ctrl_cost","type":"text"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"exclude_current_positions_from_observation","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"bool","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"True"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Version-History","level":3,"type":"heading","text":"Version History"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"url":"\/documentation\/gym\/swimmer\/model","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","abstract":[],"type":"topic","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo7MjModelV","text":"MjModel"}],"role":"symbol","title":"model","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"navigatorTitle":[{"kind":"identifier","text":"MuJoCoEnv"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MuJoCoEnv"}],"url":"\/documentation\/gym\/mujocoenv","abstract":[],"type":"topic","title":"MuJoCoEnv","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"navigatorTitle":[{"kind":"identifier","text":"Env"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"url":"\/documentation\/gym\/env","abstract":[],"type":"topic","title":"Env","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env"},"doc://org.liuliu.s4nnc/documentation/Gym":{"title":"Gym","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym","kind":"symbol","url":"\/documentation\/gym","type":"topic","abstract":[],"role":"collection"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"kind":"article","role":"collectionGroup","title":"Env Implementations","type":"topic","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","url":"\/documentation\/gym\/swimmer\/env-implementations"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"url":"\/documentation\/gym\/swimmer","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","abstract":[],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"title":"Swimmer","kind":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"title":"data","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjData","kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo6MjDataV"}],"role":"symbol","url":"\/documentation\/gym\/swimmer\/data","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","type":"topic"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","titleInlineContent":[{"text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","type":"text"}],"type":"link"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forwardRewardWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":", ","kind":"text"},{"text":"ctrlCostWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":", ","kind":"text"},{"text":"resetNoiseScale","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"role":"symbol","url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","type":"topic"}}}