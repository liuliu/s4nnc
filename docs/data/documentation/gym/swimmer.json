immer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","role":"symbol","type":"topic","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forwardRewardWeight"},{"kind":"text","text":": "},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ctrlCostWeight","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"resetNoiseScale","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"abstract":[]}}}