{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/swimmer"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"]},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"platforms":["Linux"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"Description","level":3,"text":"Description"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"type":"text","text":"links"}],"type":"strong"}]},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"rotors","type":"text"}],"type":"strong"}]},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}]},{"type":"heading","anchor":"Notes","level":3,"text":"Notes"},{"type":"paragraph","inlineContent":[{"text":"The problem parameters are:","type":"text"},{"text":" ","type":"text"},{"text":"Problem parameters:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":": number of body parts"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}]},{"type":"text","text":": mass of part "},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":": length of part "},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"type":"text","text":" ∈ {1…n})"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":": viscous-friction coefficient","type":"text"},{"text":" ","type":"text"},{"text":"While the default environment has ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" = 3, ","type":"text"},{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":" = 0.1,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the","type":"text"},{"text":" ","type":"text"},{"text":"number of links, or to tweak any of the parameters.","type":"text"}]}]}]},{"type":"heading","anchor":"Action-Space","level":3,"text":"Action Space"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"type":"emphasis","inlineContent":[{"text":"links","type":"text"}]}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Max","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unit"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the first rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor1_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor2_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]]],"header":"row"},{"type":"heading","anchor":"Observation-Space","level":3,"text":"Observation Space"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, observations consists of:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":": angle of part "},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" with respect to the "},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"type":"text","text":" axis"}]}]},{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"text":" ","type":"text"},{"text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may","type":"text"},{"text":" ","type":"text"},{"text":"be included by passing ","type":"text"},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"text":" during construction.","type":"text"},{"text":" ","type":"text"},{"text":"Then, the observation space will have 10 dimensions where the first two dimensions","type":"text"},{"text":" ","type":"text"},{"text":"represent the x- and y-coordinates of the front tip.","type":"text"},{"text":" ","type":"text"},{"text":"Regardless of whether ","type":"text"},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"will be returned in ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" with keys ","type":"text"},{"code":"\"x_position\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"y_position\"","type":"codeVoice"},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"By default, the observation is a ","type":"text"},{"code":"ndarray","type":"codeVoice"},{"text":" with shape ","type":"text"},{"code":"(8,)","type":"codeVoice"},{"text":" where the elements correspond to the following:","type":"text"},{"text":" ","type":"text"},{"text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |","type":"text"},{"text":" ","type":"text"},{"text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |","type":"text"},{"text":" ","type":"text"},{"text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Rewards","level":3,"text":"Rewards"},{"type":"paragraph","inlineContent":[{"text":"The reward consists of two parts:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"text":": A reward of moving forward which is measured","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}]},{"text":". ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"dt"}]},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"the time between actions and is dependent on the frame_skip parameter","type":"text"},{"text":" ","type":"text"},{"text":"(default is 4), where the frametime is 0.01 - making the","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}]},{"text":". This reward would be positive if the swimmer","type":"text"},{"text":" ","type":"text"},{"text":"swims right as desired.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"text":" where ","type":"text"},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"reward","type":"text"}]}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"text":"=","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"forward_reward - ctrl_cost"}],"type":"emphasis"},{"text":" and ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" will also contain the individual reward terms","type":"text"}]}]}]},{"type":"heading","anchor":"Starting-State","level":3,"text":"Starting State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":", "},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":"] is added to the initial state for stochasticity."}]},{"type":"heading","anchor":"Episode-End","level":3,"text":"Episode End"},{"type":"paragraph","inlineContent":[{"text":"The episode truncates when the episode length is greater than 1000.","type":"text"}]},{"type":"heading","anchor":"Arguments","level":3,"text":"Arguments"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}]},{"type":"codeListing","code":["gym.make('Swimmer-v4')"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"type":"codeListing","code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"syntax":null},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Parameter"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Description"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"xml_file","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}],"type":"paragraph"}],[{"inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"1.0","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"1e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"exclude_current_positions_from_observation"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"bool","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"True","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"type":"heading","anchor":"Version-History","level":3,"text":"Version History"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}],"type":"paragraph"}]}]}]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"symbolKind":"class","title":"Swimmer","externalID":"s:3Gym7SwimmerC","role":"symbol","roleHeading":"Class","modules":[{"name":"Gym"}]},"kind":"symbol","relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"abstract":[],"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","url":"\/documentation\/gym\/swimmer\/model","kind":"symbol","title":"model","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"model","kind":"identifier"},{"text":": ","kind":"text"},{"text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV","kind":"typeIdentifier"}],"role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Env","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","navigatorTitle":[{"text":"Env","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Env","url":"\/documentation\/gym\/env","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"url":"\/documentation\/gym\/swimmer\/env-implementations","kind":"article","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","type":"topic","title":"Env Implementations","role":"collectionGroup","abstract":[]},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"type":"link","identifier":"https:\/\/tel.a