{"metadata":{"roleHeading":"Class","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"modules":[{"name":"Gym"}],"externalID":"s:3Gym7SwimmerC","symbolKind":"class","title":"Swimmer","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"kind":"symbol","relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"type":"conformsTo","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gym\/swimmer"]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"languages":["swift"],"platforms":["Linux"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"Description","level":3,"text":"Description","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"text":"links","type":"text"}]}]},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"rotors","type":"text"}],"type":"strong"}]},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}]},{"anchor":"Notes","level":3,"text":"Notes","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":": number of body parts","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":": length of part "},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"type":"text","text":" ("},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" ∈ {1…n})"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"text":": viscous-friction coefficient","type":"text"},{"text":" ","type":"text"},{"text":"While the default environment has ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" = 3, ","type":"text"},{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":" = 0.1,","type":"text"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the","type":"text"},{"text":" ","type":"text"},{"text":"number of links, or to tweak any of the parameters.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Action-Space","level":3,"text":"Action Space","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"type":"emphasis","inlineContent":[{"type":"text","text":"links"}]}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Action","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Min"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Control Max"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Name (in corresponding XML file)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Unit","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the first rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor1_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"torque (N m)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor2_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]]]},{"anchor":"Observation-Space","level":3,"text":"Observation Space","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"By default, observations consists of:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":": angle of part "},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" with respect to the "},{"type":"emphasis","inlineContent":[{"text":"x","type":"text"}]},{"type":"text","text":" axis"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":"’: its derivative with respect to time (angular velocity)"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"type":"codeVoice","code":"info"},{"type":"text","text":" with keys "},{"type":"codeVoice","code":"\"x_position\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"y_position\""},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"type":"codeVoice","code":"ndarray"},{"type":"text","text":" with shape "},{"type":"codeVoice","code":"(8,)"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Rewards","level":3,"text":"Rewards","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The reward consists of two parts:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"text":": A reward of moving forward which is measured","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"type":"text","text":" * (x-coordinate before action - x-coordinate after action)\/dt"}],"type":"emphasis"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"dt"}],"type":"emphasis"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"the time between actions and is dependent on the frame_skip parameter","type":"text"},{"text":" ","type":"text"},{"text":"(default is 4), where the frametime is 0.01 - making the","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}],"type":"emphasis"},{"text":". This reward would be positive if the swimmer","type":"text"},{"text":" ","type":"text"},{"text":"swims right as desired.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"ctrl_cost","type":"text"}],"type":"emphasis"},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"text":" where ","type":"text"},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"reward"}]}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"="}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" will also contain the individual reward terms","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Starting-State","level":3,"text":"Starting State","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":", ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":"] is added to the initial state for stochasticity.","type":"text"}]},{"anchor":"Episode-End","level":3,"text":"Episode End","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}]},{"anchor":"Arguments","level":3,"text":"Arguments","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"No additional arguments are currently supported in v2 and lower.","type":"text"}]},{"syntax":null,"code":["gym.make('Swimmer-v4')"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}]},{"syntax":null,"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"type":"codeListing"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"xml_file","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"swimmer.xml\"","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Path to a MuJoCo model","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1.0"}]}],[{"type":"paragraph","inlineContent":[{"text":"Weight for ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"text":" term (see section on reward)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"float","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1e-4"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"0.1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"exclude_current_positions_from_observation"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"bool"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"True"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies"}]}]]]},{"anchor":"Version-History","level":3,"text":"Version History","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v0: Initial versions release (1.0.0)"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","title":"model","role":"symbol","kind":"symbol","url":"\/documentation\/gym\/swimmer\/model","abstract":[],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MjModel","preciseIdentifier":"s:6MuJoCo7MjModelV"}],"type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","title":"Env Implementations","url":"\/documentation\/gym\/swimmer\/env-implementations","abstract":[],"kind":"article","role":"collectionGroup"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"kind":"symbol","type":"topic","url":"\/documentation\/gym\/swimmer\/data","title":"data","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"s:6MuJoCo6MjDataV","kind":"typeIdentifier","text":"MjData"}],"role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","abstract":[]},"https://tel.archiv