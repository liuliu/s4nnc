{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","interfaceLanguage":"swift"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"]},{"title":"Default Implementations","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"generated":true}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"kind":"relationships"}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"role":"symbol","title":"Swimmer","roleHeading":"Class","symbolKind":"class","navigatorTitle":[{"text":"Swimmer","kind":"identifier"}],"modules":[{"name":"Gym"}],"externalID":"s:3Gym7SwimmerC"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"languages":["swift"]}]},{"content":[{"level":3,"text":"Description","anchor":"Description","type":"heading"},{"inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"inlineContent":[{"inlineContent":[{"text":"links","type":"text"}],"type":"strong"}],"type":"emphasis"},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"rotors"}]}],"type":"emphasis"},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}],"type":"paragraph"},{"level":3,"text":"Notes","anchor":"Notes","type":"heading"},{"inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":": number of body parts"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"m"},{"type":"text","text":"i"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}]},{"type":"text","text":": length of part "},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" ("},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"type":"text","text":" ∈ {1…n})"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"k","type":"text"}],"type":"emphasis"},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" = 3, "},{"inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}],"type":"emphasis"},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"inlineContent":[{"type":"text","text":"k"}],"type":"emphasis"},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"text":"Action Space","anchor":"Action-Space","type":"heading"},{"inlineContent":[{"type":"text","text":"The action space is a "},{"code":"Box(-1, 1, (2,), float32)","type":"codeVoice"},{"type":"text","text":". An action represents the torques applied between "},{"inlineContent":[{"text":"links","type":"text"}],"type":"emphasis"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Num","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Action"}]}],[{"type":"paragraph","inlineContent":[{"text":"Control Min","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Control Max"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Joint"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the first rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"motor1_rot"}]}],[{"type":"paragraph","inlineContent":[{"text":"hinge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"torque (N m)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Torque applied on the second rotor","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"motor2_rot","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"hinge"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"torque (N m)"}]}]]],"type":"table","header":"row"},{"level":3,"text":"Observation Space","anchor":"Observation-Space","type":"heading"},{"inlineContent":[{"text":"By default, observations consists of:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" with respect to the ","type":"text"},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"text":" axis","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":"’: its derivative with respect to time (angular velocity)","type":"text"},{"text":" ","type":"text"},{"text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may","type":"text"},{"text":" ","type":"text"},{"text":"be included by passing ","type":"text"},{"type":"codeVoice","code":"exclude_current_positions_from_observation=False"},{"text":" during construction.","type":"text"},{"text":" ","type":"text"},{"text":"Then, the observation space will have 10 dimensions where the first two dimensions","type":"text"},{"text":" ","type":"text"},{"text":"represent the x- and y-coordinates of the front tip.","type":"text"},{"text":" ","type":"text"},{"text":"Regardless of whether ","type":"text"},{"type":"codeVoice","code":"exclude_current_positions_from_observation"},{"text":" was set to true or false, the x- and y-coordinates","type":"text"},{"text":" ","type":"text"},{"text":"will be returned in ","type":"text"},{"type":"codeVoice","code":"info"},{"text":" with keys ","type":"text"},{"type":"codeVoice","code":"\"x_position\""},{"text":" and ","type":"text"},{"type":"codeVoice","code":"\"y_position\""},{"text":", respectively.","type":"text"},{"text":" ","type":"text"},{"text":"By default, the observation is a ","type":"text"},{"type":"codeVoice","code":"ndarray"},{"text":" with shape ","type":"text"},{"type":"codeVoice","code":"(8,)"},{"text":" where the elements correspond to the following:","type":"text"},{"text":" ","type":"text"},{"text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |","type":"text"},{"text":" ","type":"text"},{"text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |","type":"text"},{"text":" ","type":"text"},{"text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |","type":"text"},{"text":" ","type":"text"},{"text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |","type":"text"},{"text":" ","type":"text"},{"text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |","type":"text"},{"text":" ","type":"text"},{"text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"text":"Rewards","anchor":"Rewards","type":"heading"},{"inlineContent":[{"text":"The reward consists of two parts:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"type":"text","text":": A reward of moving forward which is measured"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"emphasis","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"text":" * (x-coordinate before action - x-coordinate after action)\/dt","type":"text"}]},{"type":"text","text":". "},{"type":"emphasis","inlineContent":[{"text":"dt","type":"text"}]},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"the time between actions and is dependent on the frame_skip parameter"},{"type":"text","text":" "},{"type":"text","text":"(default is 4), where the frametime is 0.01 - making the"},{"type":"text","text":" "},{"type":"text","text":"default "},{"type":"emphasis","inlineContent":[{"text":"dt = 4 * 0.01 = 0.04","type":"text"}]},{"type":"text","text":". This reward would be positive if the swimmer"},{"type":"text","text":" "},{"type":"text","text":"swims right as desired."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"ctrl_cost"}]},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"},{"text":" *","type":"text"},{"text":" ","type":"text"},{"text":"sum(action","type":"text"},{"text":"2","type":"text"},{"text":")","type":"text"}]},{"text":" where ","type":"text"},{"type":"emphasis","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"strong","inlineContent":[{"text":"reward","type":"text"}]}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"="}]},{"text":" ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}]},{"text":" and ","type":"text"},{"type":"codeVoice","code":"info"},{"text":" will also contain the individual reward terms","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"text":"Starting State","anchor":"Starting-State","type":"heading"},{"inlineContent":[{"type":"text","text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-"},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":", "},{"code":"reset_noise_scale","type":"codeVoice"},{"type":"text","text":"] is added to the initial state for stochasticity."}],"type":"paragraph"},{"level":3,"text":"Episode End","anchor":"Episode-End","type":"heading"},{"inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}],"type":"paragraph"},{"level":3,"text":"Arguments","anchor":"Arguments","type":"heading"},{"inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}],"type":"paragraph"},{"code":["gym.make('Swimmer-v4')"],"type":"codeListing","syntax":null},{"inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"type":"codeListing","syntax":null},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Parameter","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"xml_file"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"\"swimmer.xml\"","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1.0"}]}],[{"type":"paragraph","inlineContent":[{"text":"Weight for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"forward_reward"}]},{"text":" term (see section on reward)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"code":"1e-4","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"text":"ctrl_cost","type":"text"}]},{"type":"text","text":" term (see section on reward)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"reset_noise_scale","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"float"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"0.1","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scale of random perturbations of initial position and velocity (see section on Starting State)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"exclude_current_positions_from_observation"}]}],[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"bool"}]}]}],[{"type":"paragraph","inlineContent":[{"code":"True","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies"}]}]]],"type":"table","header":"row"},{"level":3,"text":"Version History","anchor":"Version-History","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"v2: All continuous control environments now use mujoco_py >= 1.50"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Env":{"navigatorTitle":[{"kind":"identifier","text":"Env"}],"abstract":[],"kind":"symbol","title":"Env","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Env"}],"url":"\/documentation\/gym\/env","type":"topic","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","role":"symbol"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/model":{"type":"topic","url":"\/documentation\/gym\/swimmer\/model","abstract":[],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model","title":"model","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"model"},{"kind":"text","text":": "},{"preciseIdentifier":"s:6MuJoCo7MjModelV","kind":"typeIdentifier","text":"MjModel"}]},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","abstract":[],"kind":"article","title":"Env Implementations","type":"topic","role":"collectionGroup","url":"\/documentation\/gym\/swimmer\/env-implementations"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/data":{"url":"\/documentation\/gym\/swimmer\/data","role":"symbol","abstract":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:6MuJoCo6MjDataV","text":"MjData"}],"kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","title":"data","type":"topic"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)":{"title":"init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forwardRewardWeight"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ctrlCostWeight"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"resetNoiseScale"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)","abstract":[],"type":"topic","url":"\/documentation\/gym\/swimmer\/init(forwardrewardweight:ctrlcostweight:resetnoisescale:)","role":"symbol"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”","titleInlineContent":[{"type":"text","text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}],"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"link","url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"kind":"symbol","role":"symbol","title":"MuJoCoEnv","type":"topic","navigatorTitle":[{"kind":"identifier","text":"MuJoCoEnv"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MuJoCoEnv"}],"url":"\/documentation\/gym\/mujocoenv","abstract":[],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"},"doc://org.liuliu.s4nnc/documentation/Gym":{"role":"collection","abstract":[],"title":"Gym","type":"topic","url":"\/documentation\/gym","kind":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"type":"topic","url":"\/documentation\/gym\/swimmer","abstract":[],"kind":"symbol","role":"symbol","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer","title":"Swimmer","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"navigatorTitle":[{"kind":"identifier","text":"Swimmer"}]}}}