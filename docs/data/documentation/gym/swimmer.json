{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer"},"variants":[{"paths":["\/documentation\/gym\/swimmer"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/init(forwardRewardWeight:ctrlCostWeight:resetNoiseScale:)"],"title":"Initializers"},{"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/data","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/model"],"title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations"],"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Swimmer","kind":"identifier"}],"platforms":["Linux"],"languages":["swift"]}]},{"kind":"content","content":[{"level":3,"anchor":"Description","type":"heading","text":"Description"},{"inlineContent":[{"type":"text","text":"This environment corresponds to the Swimmer environment described in Rémi Coulom’s PhD thesis"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The environment aims to increase the number of independent state and control"},{"type":"text","text":" "},{"type":"text","text":"variables as compared to the classic control environments. The swimmers"},{"type":"text","text":" "},{"type":"text","text":"consist of three or more segments (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"text":"links","type":"text"}],"type":"strong"}]},{"type":"text","text":"’) and one less articulation"},{"type":"text","text":" "},{"type":"text","text":"joints (’"},{"type":"emphasis","inlineContent":[{"inlineContent":[{"type":"text","text":"rotors"}],"type":"strong"}]},{"type":"text","text":"’) - one rotor joint connecting exactly two links to"},{"type":"text","text":" "},{"type":"text","text":"form a linear chain. The swimmer is suspended in a two dimensional pool and"},{"type":"text","text":" "},{"type":"text","text":"always starts in the same position (subject to some deviation drawn from an"},{"type":"text","text":" "},{"type":"text","text":"uniform distribution), and the goal is to move as fast as possible towards"},{"type":"text","text":" "},{"type":"text","text":"the right by applying torque on the rotors and using the fluids friction."}],"type":"paragraph"},{"level":3,"anchor":"Notes","type":"heading","text":"Notes"},{"inlineContent":[{"type":"text","text":"The problem parameters are:"},{"type":"text","text":" "},{"type":"text","text":"Problem parameters:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":": number of body parts","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"m","type":"text"},{"text":"i","type":"text"}],"type":"emphasis"},{"text":": mass of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" (","type":"text"},{"inlineContent":[{"type":"text","text":"i"}],"type":"emphasis"},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"l"},{"type":"text","text":"i"}]},{"text":": length of part ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"i"}]},{"text":" (","type":"text"},{"type":"emphasis","inlineContent":[{"text":"i","type":"text"}]},{"text":" ∈ {1…n})","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"k"}]},{"type":"text","text":": viscous-friction coefficient"},{"type":"text","text":" "},{"type":"text","text":"While the default environment has "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" = 3, "},{"type":"emphasis","inlineContent":[{"text":"l","type":"text"},{"text":"i","type":"text"}]},{"type":"text","text":" = 0.1,"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"emphasis","inlineContent":[{"text":"k","type":"text"}]},{"type":"text","text":" = 0.1. It is possible to pass a custom MuJoCo XML file during construction to increase the"},{"type":"text","text":" "},{"type":"text","text":"number of links, or to tweak any of the parameters."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Action-Space","type":"heading","text":"Action Space"},{"inlineContent":[{"type":"text","text":"The action space is a "},{"type":"codeVoice","code":"Box(-1, 1, (2,), float32)"},{"type":"text","text":". An action represents the torques applied between "},{"inlineContent":[{"text":"links","type":"text"}],"type":"emphasis"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Num"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Min","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Control Max","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Name (in corresponding XML file)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Joint","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unit"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Torque applied on the first rotor","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor1_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Torque applied on the second rotor"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"motor2_rot"}],"type":"paragraph"}],[{"inlineContent":[{"text":"hinge","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"torque (N m)"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Observation-Space","type":"heading","text":"Observation Space"},{"inlineContent":[{"type":"text","text":"By default, observations consists of:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"θ","type":"text"},{"text":"i","type":"text"},{"text":": angle of part ","type":"text"},{"inlineContent":[{"text":"i","type":"text"}],"type":"emphasis"},{"text":" with respect to the ","type":"text"},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"text":" axis","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"θ"},{"type":"text","text":"i"},{"type":"text","text":"’: its derivative with respect to time (angular velocity)"},{"type":"text","text":" "},{"type":"text","text":"In the default case, observations do not include the x- and y-coordinates of the front tip. These may"},{"type":"text","text":" "},{"type":"text","text":"be included by passing "},{"code":"exclude_current_positions_from_observation=False","type":"codeVoice"},{"type":"text","text":" during construction."},{"type":"text","text":" "},{"type":"text","text":"Then, the observation space will have 10 dimensions where the first two dimensions"},{"type":"text","text":" "},{"type":"text","text":"represent the x- and y-coordinates of the front tip."},{"type":"text","text":" "},{"type":"text","text":"Regardless of whether "},{"code":"exclude_current_positions_from_observation","type":"codeVoice"},{"type":"text","text":" was set to true or false, the x- and y-coordinates"},{"type":"text","text":" "},{"type":"text","text":"will be returned in "},{"code":"info","type":"codeVoice"},{"type":"text","text":" with keys "},{"code":"\"x_position\"","type":"codeVoice"},{"type":"text","text":" and "},{"code":"\"y_position\"","type":"codeVoice"},{"type":"text","text":", respectively."},{"type":"text","text":" "},{"type":"text","text":"By default, the observation is a "},{"code":"ndarray","type":"codeVoice"},{"type":"text","text":" with shape "},{"code":"(8,)","type":"codeVoice"},{"type":"text","text":" where the elements correspond to the following:"},{"type":"text","text":" "},{"type":"text","text":"| Num | Observation                          | Min  | Max | Name (in corresponding XML file) | Joint | Unit                     |"},{"type":"text","text":" "},{"type":"text","text":"| — | ———————————— | –– | — | –––––––––––––––– | —– | ———————— |"},{"type":"text","text":" "},{"type":"text","text":"| 0   | angle of the front tip               | -Inf | Inf | free_body_rot                    | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 1   | angle of the first rotor             | -Inf | Inf | motor1_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 2   | angle of the second rotor            | -Inf | Inf | motor2_rot                       | hinge | angle (rad)              |"},{"type":"text","text":" "},{"type":"text","text":"| 3   | velocity of the tip along the x-axis | -Inf | Inf | slider1                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 4   | velocity of the tip along the y-axis | -Inf | Inf | slider2                          | slide | velocity (m\/s)           |"},{"type":"text","text":" "},{"type":"text","text":"| 5   | angular velocity of front tip        | -Inf | Inf | free_body_rot                    | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 6   | angular velocity of first rotor      | -Inf | Inf | motor1_rot                       | hinge | angular velocity (rad\/s) |"},{"type":"text","text":" "},{"type":"text","text":"| 7   | angular velocity of second rotor     | -Inf | Inf | motor2_rot                             | hinge | angular velocity (rad\/s) |"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Rewards","type":"heading","text":"Rewards"},{"inlineContent":[{"type":"text","text":"The reward consists of two parts:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"forward_reward"}],"type":"emphasis"},{"text":": A reward of moving forward which is measured","type":"text"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"inlineContent":[{"code":"forward_reward_weight","type":"codeVoice"},{"text":" * (x-coordinate before action - x-coordinate after action)\/dt","type":"text"}],"type":"emphasis"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"dt"}],"type":"emphasis"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"the time between actions and is dependent on the frame_skip parameter","type":"text"},{"text":" ","type":"text"},{"text":"(default is 4), where the frametime is 0.01 - making the","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"inlineContent":[{"type":"text","text":"dt = 4 * 0.01 = 0.04"}],"type":"emphasis"},{"text":". This reward would be positive if the swimmer","type":"text"},{"text":" ","type":"text"},{"text":"swims right as desired.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"ctrl_cost","type":"text"}],"type":"emphasis"},{"text":": A cost for penalising the swimmer if it takes","type":"text"},{"text":" ","type":"text"},{"text":"actions that are too large. It is measured as ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"},{"type":"text","text":" *"},{"type":"text","text":" "},{"type":"text","text":"sum(action"},{"type":"text","text":"2"},{"type":"text","text":")"}],"type":"emphasis"},{"text":" where ","type":"text"},{"inlineContent":[{"code":"ctrl_cost_weight","type":"codeVoice"}],"type":"emphasis"},{"text":" is a parameter set for the","type":"text"},{"text":" ","type":"text"},{"text":"control and has a default value of 1e-4","type":"text"},{"text":" ","type":"text"},{"text":"The total reward returned is ","type":"text"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"reward","type":"text"}]}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"="}],"type":"emphasis"},{"text":" ","type":"text"},{"inlineContent":[{"text":"forward_reward - ctrl_cost","type":"text"}],"type":"emphasis"},{"text":" and ","type":"text"},{"code":"info","type":"codeVoice"},{"text":" will also contain the individual reward terms","type":"text"}]}]}],"type":"unorderedList"},{"level":3,"anchor":"Starting-State","type":"heading","text":"Starting State"},{"inlineContent":[{"text":"All observations start in state (0,0,0,0,0,0,0,0) with a Uniform noise in the range of [-","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":", ","type":"text"},{"code":"reset_noise_scale","type":"codeVoice"},{"text":"] is added to the initial state for stochasticity.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Episode-End","type":"heading","text":"Episode End"},{"inlineContent":[{"type":"text","text":"The episode truncates when the episode length is greater than 1000."}],"type":"paragraph"},{"level":3,"anchor":"Arguments","type":"heading","text":"Arguments"},{"inlineContent":[{"type":"text","text":"No additional arguments are currently supported in v2 and lower."}],"type":"paragraph"},{"syntax":null,"code":["gym.make('Swimmer-v4')"],"type":"codeListing"},{"inlineContent":[{"text":"v3 and v4 take gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc.","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["env = gym.make('Swimmer-v4', ctrl_cost_weight=0.1, ....)"],"type":"codeListing"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Parameter","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Default"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Description","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"xml_file"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"str"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"\"swimmer.xml\""}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Path to a MuJoCo model"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"forward_reward_weight"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"1.0","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Weight for "},{"type":"emphasis","inlineContent":[{"text":"forward_reward","type":"text"}]},{"type":"text","text":" term (see section on reward)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"ctrl_cost_weight"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"text":"float","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"1e-4","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Weight for ","type":"text"},{"inlineContent":[{"type":"text","text":"ctrl_cost"}],"type":"emphasis"},{"text":" term (see section on reward)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"reset_noise_scale"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"float"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"0.1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Scale of random perturbations of initial position and velocity (see section on Starting State)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"exclude_current_positions_from_observation"}],"type":"paragraph"}],[{"inlineContent":[{"inlineContent":[{"type":"text","text":"bool"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"code":"True","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether or not to omit the x- and y-coordinates from observations. Excluding the position can serve as an inductive bias to induce position-agnostic behavior in policies"}],"type":"paragraph"}]]]},{"level":3,"anchor":"Version-History","type":"heading","text":"Version History"},{"items":[{"content":[{"inlineContent":[{"text":"v4: all mujoco environments now use the mujoco bindings in mujoco>=2.1.3","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"v3: support for gym.make kwargs such as xml_file, ctrl_cost_weight, reset_noise_scale etc. rgb rendering comes from tracking camera (so agent does not run away from screen)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v2: All continuous control environments now use mujoco_py >= 1.50","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v1: max_time_steps raised to 1000 for robot based tasks. Added reward_threshold to environments.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"v0: Initial versions release (1.0.0)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"hierarchy":{"paths":[["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym"]]},"metadata":{"symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Swimmer"}],"externalID":"s:3Gym7SwimmerC","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Swimmer"}],"roleHeading":"Class","modules":[{"name":"Gym"}],"title":"Swimmer"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Env","doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv"],"title":"Conforms To","type":"conformsTo"}],"references":{"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer/Env-Implementations":{"abstract":[],"title":"Env Implementations","role":"collectionGroup","identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/Swimmer\/Env-Implementations","url":"\/documentation\/gym\/swimmer\/env-implementations","kind":"article","type":"topic"},"https://tel.archives-ouvertes.fr/tel-00003985/document":{"titleInlineContent":[{"type":"text","text":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"}],"identifier":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","type":"link","url":"https:\/\/tel.archives-ouvertes.fr\/tel-00003985\/document","title":"“Reinforcement Learning Using Neural Networks, with Applications to Motor Control”"},"doc://org.liuliu.s4nnc/documentation/Gym/MuJoCoEnv":{"kind":"symbol","abstract":[],"role":"symbol","navigatorTitle":[{"text":"MuJoCoEnv","kind":"identifier"}],"title":"MuJoCoEnv","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MuJoCoEnv","kind":"identifier"}],"identifier":"doc:\/\/org.liuliu.s4nnc\/documentation\/Gym\/MuJoCoEnv","url":"\/documentation\/gym\/mujocoenv"},"doc://org.liuliu.s4nnc/documentation/Gym/Swimmer":{"kind":"symbol","abstract":[],"role":"symbol","navigat